  function saveThresholds() {
    const hi = parseFloat(document.getElementById('scoreThresholdHighInput')?.value);
    const lo = parseFloat(document.getElementById('scoreThresholdLowInput')?.value);
    if (isNaN(hi)||isNaN(lo)) return alert('Nhập giá trị số');
    if (hi<0||hi>1||lo<0||lo>1) return alert('Giá trị 0-1');
    if (lo>=hi) return alert('Ngưỡng thấp < ngưỡng cao');
    fetch('/api/settings/thresholds', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({scoreThresholdHigh:hi,scoreThresholdLow:lo}) })
      .then(r=>r.json()).then(d => {
        if (d.success) {
          const el = document.getElementById('thresholdStatus');
          if (el) { el.textContent = `Cao: ${hi} | Thấp: ${lo}`; el.style.color = '#28a745'; }
          const f = document.getElementById('thresholdForm');
          if (f) { const c = bootstrap.Collapse.getInstance(f); if (c) c.hide(); }
          showToast('Đã lưu thresholds!', 'success');
        } else alert('Lỗi: ' + (d.error||d.message));
      }).catch(()=>alert('Lỗi kết nối'));
  }

