  function loadCurrentSettings() {
    const loadSetting = (url, callback) => {
      fetch(url).then(r=>r.json()).then(callback).catch(()=>{});
    };
    loadSetting('/api/settings/gemini-api-key', data => {
      if (!data.success) return;
      const el = document.getElementById('geminiApiKeyStatus');
      if (el) { el.textContent = data.value?.trim() ? data.value : '(not set)'; el.style.color = data.value?.trim() ? '#28a745' : '#6c757d'; }
    });
    loadSetting('/api/settings/current-model', data => {
      if (!data.success) return;
      const el = document.getElementById('currentModel');
      if (el) { el.textContent = data.value?.trim() ? data.value : '(not set)'; el.style.color = data.value?.trim() ? '#28a745' : '#6c757d'; }
    });
    loadSetting('/api/settings/ai-enabled', data => {
      if (!data.success) return;
      const t = document.getElementById('aiToggleSwitch'), txt = document.getElementById('aiToggleText');
      if (t) t.checked = data.value;
      if (txt) txt.textContent = data.value ? 'Đang bật' : 'Đang tắt';
    });
    loadSetting('/api/settings/ai-train-enabled', data => {
      if (!data.success) return;
      const t = document.getElementById('aiTrainToggleSwitch'), txt = document.getElementById('aiTrainToggleText');
      if (t) t.checked = data.value;
      if (txt) txt.textContent = data.value ? 'Đang bật' : 'Đang tắt';
    });
    loadSetting('/api/settings/page-access-token', data => {
      if (!data.success) return;
      const el = document.getElementById('pageTokenStatus');
      if (el) { el.textContent = data.value?.trim() ? data.value : '(not set)'; el.style.color = data.value?.trim() ? '#28a745' : '#6c757d'; }
    });
    loadSetting('/api/settings/verify-token', data => {
      if (!data.success) return;
      const el = document.getElementById('verifyTokenStatus');
      if (el) { el.textContent = data.value?.trim() ? data.value : '(not set)'; el.style.color = data.value?.trim() ? '#28a745' : '#6c757d'; }
    });
    loadSetting('/api/settings/ai-prompt', data => {
      if (!data.success) return;
      const el = document.getElementById('aiPromptStatus'), inp = document.getElementById('aiPromptInput');
      if (el) { el.textContent = data.value?.trim() ? data.value.substring(0,50) + (data.value.length>50?'...':'') : 'Click để chỉnh sửa'; el.style.color = data.value?.trim() ? '#28a745' : '#6c757d'; }
      if (inp) inp.value = data.value || '';
    });
    loadSetting('/api/settings/thresholds', data => {
      if (!data.success) return;
      const el = document.getElementById('thresholdStatus');
      if (el) { el.textContent = `Cao: ${data.scoreThresholdHigh||0.4} | Thấp: ${data.scoreThresholdLow||0.3}`; el.style.color = '#28a745'; }
      const hi = document.getElementById('scoreThresholdHighInput'), lo = document.getElementById('scoreThresholdLowInput');
      if (hi) hi.value = data.scoreThresholdHigh || 0.4;
      if (lo) lo.value = data.scoreThresholdLow || 0.3;
    });
  }

  function saveGeminiApiKey() {
    const input = document.getElementById('geminiApiKeyInput'); if (!input) return;
    const val = input.value; if (!val.trim()) return alert('Nhập GEMINI API KEY');
    fetch('/api/settings/gemini-api-key', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({value:val}) })
      .then(r=>r.json()).then(d => {
        if (d.success) {
          const el = document.getElementById('geminiApiKeyStatus');
          if (el) { el.textContent = val; el.style.color = '#28a745'; }
          input.value = '';
          const f = document.getElementById('geminiApiKeyForm');
          if (f) { const c = bootstrap.Collapse.getInstance(f); if (c) c.hide(); }
          showToast('Đã lưu API Key!', 'success');
        } else alert('Lỗi: ' + d.message);
      }).catch(()=>alert('Lỗi kết nối'));
  }

