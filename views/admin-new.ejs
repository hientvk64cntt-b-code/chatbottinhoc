  async function loadGenAIStatus() {
    try {
      const genaiModelEl = document.getElementById('genaiModel');
      const useAICheckEl = document.getElementById('useAICheck');
      if (!genaiModelEl && !useAICheckEl) return;
      if (genaiModelEl) { const m = await fetch('/admin/genai-model').then(r=>r.json()); genaiModelEl.innerText = m.model||'(not set)'; }
      if (useAICheckEl) { const u = await fetch('/admin/use-ai').then(r=>r.json()); useAICheckEl.checked = !!u.useAI; }
      const toks = await fetch('/admin/tokens').then(r=>r.json());
      const el = id => document.getElementById(id);
      if (el('apiKeyMasked')) el('apiKeyMasked').innerText = toks.genaiApiKey ? '(API key set)' : '(not set)';
      if (el('maskedTokens')) el('maskedTokens').innerText = `API: ${toks.genaiApiKey||'(none)'} | PAGE: ${toks.pageAccessToken||'(none)'} | VERIFY: ${toks.verifyToken||'(none)'}`;
      updateNgrokStatusForSettings();
    } catch(e) { console.error('loadGenAIStatus error', e); }
  }

