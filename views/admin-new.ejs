  }
  loadAIStatus();

  // ═══════════════════════════════════════════════════════════════
  // NGROK
  // ═══════════════════════════════════════════════════════════════
  function updateNgrokStatus() {
    fetch('/admin/ngrok-status').then(r => r.json()).then(data => {
      const statusDiv = document.getElementById('ngrokStatus');
      const ngrokBtn = document.getElementById('ngrokBtn');
      const forceKillBtn = document.getElementById('ngrokForceKillBtn');
      const topIndicator = document.getElementById('ngrokTopIndicator');
      const ngrokDot = document.getElementById('ngrokDot');
      const ngrokLabel = document.getElementById('ngrokStatusLabel');

      if (data.active && data.url) {
        statusDiv.innerHTML = `<a href='${data.url}/webhook' target='_blank' class='ngrok-url'>${data.url}/webhook</a> <button id='copyNgrokUrl' class='btn btn-sm btn-outline-secondary ms-2'><i class='fa fa-copy'></i></button>`;
        setTimeout(() => {
          const cb = document.getElementById('copyNgrokUrl');
          if (cb) cb.onclick = () => { navigator.clipboard.writeText(data.url + '/webhook').then(() => { cb.innerHTML = '<i class="fa fa-check"></i>'; setTimeout(() => { cb.innerHTML = '<i class="fa fa-copy"></i>'; }, 1500); }); };
        }, 50);
        ngrokBtn.className = 'btn btn-danger btn-sm'; ngrokBtn.innerHTML = '<i class="fa fa-power-off"></i> Tắt';
        ngrokBtn.dataset.active = 'true'; forceKillBtn.style.display = 'inline-block';
        if (topIndicator) { topIndicator.className = 'ngrok-indicator active'; topIndicator.querySelector('span').textContent = 'Ngrok ON'; }
        if (ngrokDot) ngrokDot.className = 'status-dot on';
        if (ngrokLabel) ngrokLabel.textContent = 'Đang chạy';
        const badge = document.getElementById('ngrokStatusBadge');
        if (badge) { badge.innerText = 'Đang chạy'; badge.className = 'badge bg-success me-2'; }
      } else {
        statusDiv.innerHTML = '<span class="text-muted small">Chưa bật</span>';
        ngrokBtn.className = 'btn btn-info btn-sm'; ngrokBtn.innerHTML = '<i class="fa fa-bolt"></i> Bật ngrok';
        ngrokBtn.dataset.active = 'false'; forceKillBtn.style.display = 'none';
        if (topIndicator) { topIndicator.className = 'ngrok-indicator'; topIndicator.querySelector('span').textContent = 'Ngrok tắt'; }
        if (ngrokDot) ngrokDot.className = 'status-dot off';
        if (ngrokLabel) ngrokLabel.textContent = 'Chưa bật';
        const badge = document.getElementById('ngrokStatusBadge');
        if (badge) { badge.innerText = 'Chưa bật'; badge.className = 'badge bg-secondary me-2'; }
      }
    });
  }
  function updateNgrokStatusForSettings() { updateNgrokStatus(); }

  document.getElementById('ngrokBtn').onclick = function() {
    const ngrokBtn = this; const statusDiv = document.getElementById('ngrokStatus');
    ngrokBtn.disabled = true;
    if (ngrokBtn.dataset.active === 'true') {
      ngrokBtn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Tắt...';
      fetch('/admin/ngrok/stop', { method: 'POST' }).then(r => r.json()).then(data => {
        ngrokBtn.disabled = false; updateNgrokStatus();
        if (!data.success) alert('Lỗi: ' + (data.error || data.message));
      }).catch(e => { ngrokBtn.disabled = false; updateNgrokStatus(); alert('Lỗi: ' + e.message); });
    } else {
      ngrokBtn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Bật...';
      fetch('/admin/ngrok', { method: 'POST' }).then(r => r.json()).then(data => {
        ngrokBtn.disabled = false; updateNgrokStatus();
        if (!data.success) alert('Lỗi ngrok: ' + data.error);
      }).catch(e => { ngrokBtn.disabled = false; updateNgrokStatus(); alert('Lỗi: ' + e.message); });
    }
  };
  document.getElementById('ngrokForceKillBtn').onclick = function() {
    if (!confirm('Force kill ngrok?')) return;
    const btn = this; btn.disabled = true; btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i>';
    fetch('/admin/ngrok/force-kill', { method: 'POST' }).then(r => r.json()).then(data => {
      btn.disabled = false; btn.innerHTML = '<i class="fa fa-exclamation-triangle"></i> Force Kill';
      updateNgrokStatus(); alert(data.success ? '✅ ' + data.message : '❌ ' + (data.error || data.message));
    }).catch(e => { btn.disabled = false; btn.innerHTML = '<i class="fa fa-exclamation-triangle"></i> Force Kill'; updateNgrokStatus(); });
  };
  updateNgrokStatus();

  // ═══════════════════════════════════════════════════════════════
