      .catch(() => updateAIStatusDisplay(false));
    fetch('/api/settings/ai-train-enabled')
      .then(r => r.json())
      .then(data => { if (data.success) updateAITrainStatusDisplay(data.value); })
      .catch(() => updateAITrainStatusDisplay(false));
  }
  function updateAIStatusDisplay(on) {
    const dot = document.getElementById('aiDot');
    const label = document.getElementById('aiStatusLabel');
    if (dot) { dot.className = 'status-dot ' + (on ? 'on' : 'off'); }
    if (label) label.textContent = on ? 'Đang bật' : 'Đang tắt';
  }
  function updateAITrainStatusDisplay(on) {
    const dot = document.getElementById('trainDot');
    const label = document.getElementById('trainStatusLabel');
    if (dot) { dot.className = 'status-dot ' + (on ? 'on' : 'off'); }
