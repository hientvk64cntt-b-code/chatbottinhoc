  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

  <script>
  // ═══════════════════════════════════════════════════════════════
  // SIDEBAR & NAVIGATION
  // ═══════════════════════════════════════════════════════════════
  document.addEventListener('DOMContentLoaded', function() {
    const url = new URL(window.location.href);
    const currentTab = url.searchParams.get('tab') || 'qna';

    // Sidebar toggle (mobile)
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebarOverlay');
    const toggleBtn = document.getElementById('sidebarToggle');

    toggleBtn.addEventListener('click', function() {
      sidebar.classList.toggle('open');
      overlay.classList.toggle('show');
    });
    overlay.addEventListener('click', function() {
      sidebar.classList.remove('open');
      overlay.classList.remove('show');
    });

    // Show/hide topbar search & filter based on active section
    function updateTopbar(section) {
      const searchWrapper = document.getElementById('topbarSearchWrapper');
      const filterWrapper = document.getElementById('topbarFilterWrapper');
      if (section === 'qna') {
        searchWrapper.style.display = '';
        filterWrapper.style.display = '';
      } else {
        searchWrapper.style.display = 'none';
        filterWrapper.style.display = 'none';
      }
    }

    // Initialize sections
    function initSections() {
      document.querySelectorAll('.section-panel').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.sidebar-link').forEach(l => l.classList.remove('active'));
      const activePanel = document.getElementById('section-' + currentTab);
      const activeLink = document.getElementById(currentTab + '-tab');
      if (activePanel) activePanel.classList.add('active');
      if (activeLink) activeLink.classList.add('active');
      updateTopbar(currentTab);

      if (currentTab === 'default-responses') {
        setTimeout(() => { if (typeof loadDefaultResponses === 'function') loadDefaultResponses(); }, 300);
      }
    }
    initSections();

    // Sidebar link clicks
    document.querySelectorAll('.sidebar-link').forEach(link => {
      link.addEventListener('click', function() {
        const section = this.dataset.section;
        const navUrl = new URL(window.location.href);
        navUrl.searchParams.set('tab', section);
        if (section === 'settings') {
          navUrl.searchParams.delete('page');
          navUrl.searchParams.delete('pagePending');
        }
        window.location.href = navUrl.toString();
      });
    });

    // Import success check
    if (url.searchParams.get('import') === 'success') {
      const success = url.searchParams.get('success') || 0;
      const duplicate = url.searchParams.get('duplicate') || 0;
      const error = url.searchParams.get('error') || 0;
      let message = '';
      if (success > 0) message += `✅ Thêm ${success} câu hỏi. `;
      if (duplicate > 0) message += `⚠️ Bỏ qua ${duplicate} trùng. `;
      if (error > 0) message += `❌ ${error} lỗi. `;
      showToast(message || 'Import hoàn tất', success > 0 ? 'success' : 'warning');
      url.searchParams.delete('import'); url.searchParams.delete('success');
      url.searchParams.delete('duplicate'); url.searchParams.delete('error');
      window.history.replaceState({}, '', url.toString());
    } else if (url.searchParams.get('import') === 'error') {
      showToast('Import thất bại: ' + (url.searchParams.get('message') || 'Lỗi'), 'danger');
      url.searchParams.delete('import'); url.searchParams.delete('message');
      window.history.replaceState({}, '', url.toString());
    }
  });

  // ═══════════════════════════════════════════════════════════════
  // AI / TRAIN STATUS (sidebar)
  // ═══════════════════════════════════════════════════════════════
  function loadAIStatus() {
    fetch('/api/settings/ai-enabled')
      .then(r => r.json())
