  function toggleEditForm(formId) {
    const el = document.getElementById(formId);
    if (!el) return;
    const c = bootstrap.Collapse.getInstance(el);
    if (c) c.toggle(); else new bootstrap.Collapse(el).toggle();
  }

  function loadAvailableModels() {
    const list = document.getElementById('modelsList'), btn = document.getElementById('loadModelsBtn');
    if (!list||!btn) return;
    btn.textContent = 'Đang tải...'; btn.disabled = true;
    fetch('/api/models/available').then(r=>r.json()).then(data => {
      if (data.success && data.models?.length > 0) {
        list.innerHTML = '';
        data.models.forEach(m => {
          const item = document.createElement('div'); item.className = 'model-item';
          item.innerHTML = `<span class="model-name">${m}</span><span class="model-status">Available</span>`;
          item.addEventListener('click', () => selectModel(m));
          list.appendChild(item);
        });
      } else { list.innerHTML = '<div class="text-danger small">❌ ' + (data.error || 'Không thể tải') + '</div>'; }
    }).catch(()=>{ list.innerHTML = '<div class="text-danger small">Lỗi kết nối</div>'; })
    .finally(()=>{ btn.textContent = 'Tải danh sách'; btn.disabled = false; });
  }

  function selectModel(modelName) {
    document.querySelectorAll('.model-item').forEach(i => i.classList.remove('selected'));
    if (event?.target) event.target.closest('.model-item')?.classList.add('selected');
    fetch('/api/settings/current-model', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({model:modelName}) })
      .then(r=>r.json()).then(d => {
        if (d.success) {
          const el = document.getElementById('currentModel');
          if (el) { el.textContent = modelName; el.style.color = '#28a745'; }
          toggleEditForm('modelSelectForm');
          showToast('Model: ' + modelName, 'success');
        } else alert('Lỗi: ' + d.message);
      }).catch(()=>alert('Lỗi kết nối'));
  }

  function testGeminiApiForModels() {
    const btn = document.getElementById('testApiBtn'); if (!btn) return;
    btn.textContent = 'Test...'; btn.disabled = true;
    fetch('/api/test/gemini').then(r=>r.json()).then(d => {
      if (d.success) { const wm = d.probe?.filter(p=>p.ok)||[]; alert('✅ API OK!\nWorking: ' + wm.map(m=>m.model).join(', ')); }
      else alert('❌ ' + d.error);
    }).catch(e=>alert('❌ ' + e.message)).finally(()=>{ btn.textContent = 'Test API'; btn.disabled = false; });
  }
  function reloadApiKey() {
    const btn = document.getElementById('reloadApiBtn'); if (!btn) return;
    btn.textContent = 'Reload...'; btn.disabled = true;
    fetch('/api/settings/gemini-api-key').then(r=>r.json()).then(d => {
      if (d.success && d.value) {
        fetch('/api/settings/gemini-api-key', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({value:d.value}) })
          .then(r=>r.json()).then(r => { alert(r.success ? '✅ Reload OK!' : '❌ ' + r.error); });
      } else alert('❌ Không tìm thấy API Key');
    }).catch(e=>alert('❌ ' + e.message)).finally(()=>{ btn.textContent = 'Reload Key'; btn.disabled = false; });
  }
  function forceSwitchToFlash() {
    if (!confirm('Chuyển sang gemini-2.0-flash?')) return;
    const cur = document.getElementById('currentModel')?.textContent;
    fetch('/api/models/force-switch', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({fromModel:cur,toModel:'models/gemini-2.0-flash'}) })
      .then(r=>r.json()).then(d => {
        if (d.success) {
          const el = document.getElementById('currentModel');
          if (el) { el.textContent = 'models/gemini-2.0-flash'; el.style.color = '#28a745'; }
          toggleEditForm('modelSelectForm');
          showToast('Đã chuyển sang gemini-2.0-flash', 'success');
        } else alert('❌ ' + d.error);
      }).catch(e=>alert('❌ ' + e.message));
