  function toggleAI() {
    const t = document.getElementById('aiToggleSwitch'), txt = document.getElementById('aiToggleText');
    if (!t||!txt) return;
    const on = t.checked;
    fetch('/api/settings/ai-enabled', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({value:on}) })
      .then(r=>r.json()).then(d => {
        if (d.success) { txt.textContent = on ? 'Đang bật' : 'Đang tắt'; updateAIStatusDisplay(on); showToast(on ? 'AI đã bật' : 'AI đã tắt', 'info'); }
        else { t.checked = !on; txt.textContent = !on ? 'Đang bật' : 'Đang tắt'; }
      }).catch(()=>{ t.checked = !on; txt.textContent = !on ? 'Đang bật' : 'Đang tắt'; });
  }
  function toggleAITrain() {
    const t = document.getElementById('aiTrainToggleSwitch'), txt = document.getElementById('aiTrainToggleText');
    if (!t||!txt) return;
    const on = t.checked;
    fetch('/api/settings/ai-train-enabled', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({value:on}) })
      .then(r=>r.json()).then(d => {
        if (d.success) { txt.textContent = on ? 'Đang bật' : 'Đang tắt'; updateAITrainStatusDisplay(on); showToast(on ? 'Train AI đã bật' : 'Train AI đã tắt', 'info'); }
        else { t.checked = !on; txt.textContent = !on ? 'Đang bật' : 'Đang tắt'; }
      }).catch(()=>{ t.checked = !on; txt.textContent = !on ? 'Đang bật' : 'Đang tắt'; });
