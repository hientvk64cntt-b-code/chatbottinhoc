  // ═══════════════════════════════════════════════════════════════
  // ADD / REMOVE ANSWERS
  // ═══════════════════════════════════════════════════════════════
  document.addEventListener('DOMContentLoaded', function() {
    // QNA add answer
    document.querySelectorAll('[id^="add-answer-"]').forEach(button => {
      button.addEventListener('click', function() {
        const qid = this.id.split('-')[2];
        const container = document.getElementById('answers-container-' + qid);
        if (!container) return;
        const count = container.querySelectorAll('.answer-item').length + 1;
        const item = document.createElement('div');
        item.className = 'answer-item mb-2';
        item.innerHTML = `<div class="d-flex align-items-start gap-2"><div class="flex-grow-1"><label class="form-label small text-muted">Trả lời ${count}:</label><textarea name="answers[]" class="form-control auto-expand" rows="2" placeholder="Nhập câu trả lời..."></textarea></div><button type="button" class="btn btn-outline-danger btn-sm ms-1 remove-answer"><i class="fa fa-times"></i></button></div>`;
        container.appendChild(item);
        item.querySelector('textarea').focus();
        item.querySelector('.remove-answer').addEventListener('click', () => { item.remove(); updateLabels(container); });
      });
    });

    // Pending add answer
    document.querySelectorAll('[id^="pending-add-answer-"]').forEach(button => {
      button.addEventListener('click', function() {
        const qid = this.id.split('-')[3];
        const container = document.getElementById('pending-answers-container-' + qid);
        if (!container) return;
        const count = container.querySelectorAll('.answer-item').length + 1;
        const item = document.createElement('div');
        item.className = 'answer-item mb-2';
        item.innerHTML = `<div class="d-flex align-items-start gap-2"><div class="flex-grow-1"><label class="form-label small text-muted">Trả lời ${count}:</label><textarea name="answers[]" class="form-control auto-expand" rows="2" placeholder="Nhập câu trả lời..."></textarea></div><button type="button" class="btn btn-outline-danger btn-sm ms-1 remove-answer"><i class="fa fa-times"></i></button></div>`;
        container.appendChild(item);
        item.querySelector('textarea').focus();
        item.querySelector('.remove-answer').addEventListener('click', () => { item.remove(); updateLabels(container); });
      });
    });

    // Remove answer (existing)
    document.querySelectorAll('.remove-answer').forEach(btn => {
      btn.addEventListener('click', function() {
        const item = this.closest('.answer-item');
        const container = item?.closest('.answers-container');
        if (container && container.querySelectorAll('.answer-item').length <= 1) return alert('Cần ít nhất 1 câu trả lời!');
        if (item) item.remove();
        if (container) updateLabels(container);
      });
    });

    function updateLabels(container) {
      container.querySelectorAll('.answer-item').forEach((item, i) => {
        const label = item.querySelector('label');
        if (label) label.textContent = `Trả lời ${i + 1}:`;
      });
    }

    // Form validations
    document.querySelectorAll('.edit-form').forEach(form => {
      form.addEventListener('submit', function(e) {
        const answers = this.querySelectorAll('textarea[name="answers[]"]');
        let hasValid = false;
        answers.forEach(t => { if (t.value.trim()) hasValid = true; });
        if (!hasValid) { e.preventDefault(); return alert('Cần ít nhất 1 câu trả lời!'); }
        if (!confirm('Lưu thay đổi?')) { e.preventDefault(); }
      });
    });
    document.querySelectorAll('.pending-edit-form').forEach(form => {
      form.addEventListener('submit', function(e) {
        const answers = this.querySelectorAll('textarea[name="answers[]"]');
        let hasValid = false;
        answers.forEach(t => { if (t.value.trim()) hasValid = true; });
        if (!hasValid) { e.preventDefault(); return alert('Cần ít nhất 1 câu trả lời!'); }
        if (!confirm('Gửi trả lời? Câu hỏi sẽ chuyển sang "Đã có trả lời".')) { e.preventDefault(); }
      });
    });

    // Delete pending (AJAX)
    document.querySelectorAll('.btn-delete-pending').forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        if (!confirm('Xóa câu hỏi này?')) return;
        const id = this.dataset.id;
        const pagePending = new URL(window.location.href).searchParams.get('pagePending') || 1;
        fetch(`/admin/delete-pending/${id}?tab=pending&pagePending=${pagePending}`, {
          method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' }
        }).then(r => { if (r.ok) window.location.reload(); else alert('Xóa thất bại!'); }).catch(()=>alert('Lỗi kết nối!'));
      });
    });

    // Auto-expand textareas
    document.querySelectorAll('.auto-expand').forEach(ta => {
      const expand = () => { ta.style.height = 'auto'; ta.style.height = ta.scrollHeight + 'px'; };
      ta.addEventListener('input', expand);
      expand();
    });
  });

  // ═══════════════════════════════════════════════════════════════
  // CHAT WIDGET
  // ═══════════════════════════════════════════════════════════════
  document.addEventListener('DOMContentLoaded', function() {
    const chatWidget = document.getElementById('chatWidget');
    const chatMessages = document.getElementById('chatMessages');
    const chatInput = document.getElementById('chatInput');
    const sendBtn = document.getElementById('sendMessage');
    const toggleBtn = document.getElementById('toggleChat');
    const currentTimeEl = document.getElementById('currentTime');
    let isCollapsed = true;

    function updateTime() {
      const now = new Date();
      if (currentTimeEl) currentTimeEl.textContent = now.toLocaleTimeString('vi-VN', { hour:'2-digit', minute:'2-digit' });
    }
    updateTime(); setInterval(updateTime, 1000);

    toggleBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      isCollapsed = !isCollapsed;
      chatWidget.classList.toggle('expanded', !isCollapsed);
      toggleBtn.querySelector('i').className = isCollapsed ? 'fa fa-plus' : 'fa fa-minus';
    });

    function sendMessage() {
      const msg = chatInput.value.trim(); if (!msg) return;
      addMessage(msg, 'user'); chatInput.value = '';
      showTyping();
      fetch('/admin/test-message', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({message:msg,useAI:true}) })
        .then(r=>r.json()).then(d => { hideTyping(); addMessage(d.success && d.reply ? d.reply : 'Lỗi xử lý', d.success ? 'bot' : 'bot'); })
        .catch(()=>{ hideTyping(); addMessage('Không thể kết nối server', 'bot'); });
    }

    function addMessage(text, sender) {
      const div = document.createElement('div');
      div.className = 'message ' + sender + '-message';
      const time = new Date().toLocaleTimeString('vi-VN', { hour:'2-digit', minute:'2-digit' });
      div.innerHTML = sender === 'bot'
        ? `<div class="message-content"><i class="fa fa-robot"></i><span>${text}</span></div><div class="message-time">${time}</div>`
        : `<div class="message-content"><span>${text}</span></div><div class="message-time">${time}</div>`;
      chatMessages.appendChild(div);
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function showTyping() {
      const div = document.createElement('div');
      div.className = 'message bot-message typing-message';
      div.innerHTML = '<div class="typing-indicator"><div class="typing-dots"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div></div>';
      chatMessages.appendChild(div);
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }
    function hideTyping() { const t = chatMessages.querySelector('.typing-message'); if (t) t.remove(); }

    sendBtn.addEventListener('click', sendMessage);
    chatInput.addEventListener('keypress', e => { if (e.key === 'Enter') sendMessage(); });
    chatWidget.addEventListener('click', function() {
      if (isCollapsed) { isCollapsed = false; chatWidget.classList.add('expanded'); toggleBtn.querySelector('i').className = 'fa fa-minus'; setTimeout(()=>chatInput.focus(), 300); }
    });
  });

  // ═══════════════════════════════════════════════════════════════
  // DEFAULT RESPONSES
  // ═══════════════════════════════════════════════════════════════
  let defaultResponses = [];

  async function loadDefaultResponses() {
    try {
      const res = await fetch('/api/default-responses');
      const data = await res.json();
      if (data.success) { defaultResponses = data.responses; renderDefaultResponses(); }
    } catch(e) { console.error('Error loading default responses', e); }
  }

  function renderDefaultResponses() {
    const container = document.getElementById('defaultResponsesList');
    if (!container) return;
    if (defaultResponses.length === 0) {
      container.innerHTML = '<div class="text-center py-4 w-100" style="color:var(--text-muted);"><i class="fa fa-inbox fa-2x mb-2 d-block"></i>Chưa có câu trả lời mặc định</div>';
      return;
    }
    container.innerHTML = defaultResponses.map(r => `
      <div class="dr-card">
        <div class="dr-header"><span class="dr-title">${escapeHtml(r.name)}</span><span class="dr-priority">Ưu tiên ${r.priority}</span></div>
        <div class="dr-body">
          <div class="dr-message">${escapeHtml(r.message)}</div>
          <div class="dr-footer">
            <span class="dr-status ${r.isActive?'active':'inactive'}"><i class="fa fa-${r.isActive?'check-circle':'times-circle'}"></i> ${r.isActive?'Hoạt động':'Tạm dừng'}</span>
            <div class="d-flex gap-1">
              <button class="btn btn-outline-primary btn-sm" onclick="editDefaultResponse('${r._id}')"><i class="fa fa-edit"></i></button>
              <button class="btn btn-outline-danger btn-sm" onclick="deleteDefaultResponse('${r._id}')"><i class="fa fa-trash"></i></button>
            </div>
          </div>
        </div>
      </div>`).join('');
  }

  function showAddDefaultResponseModal() {
    document.getElementById('defaultResponseModalLabel').textContent = 'Thêm câu trả lời mặc định';
    document.getElementById('defaultResponseForm').reset();
    document.getElementById('defaultResponseId').value = '';
    document.getElementById('defaultResponseActive').checked = true;
    document.getElementById('defaultResponsePriority').value = '1';
    new bootstrap.Modal(document.getElementById('defaultResponseModal')).show();
  }
  function editDefaultResponse(id) {
    const r = defaultResponses.find(x => x._id === id); if (!r) return;
    document.getElementById('defaultResponseModalLabel').textContent = 'Chỉnh sửa';
    document.getElementById('defaultResponseId').value = r._id;
    document.getElementById('defaultResponseName').value = r.name;
    document.getElementById('defaultResponseMessage').value = r.message;
    document.getElementById('defaultResponsePriority').value = r.priority;
    document.getElementById('defaultResponseActive').checked = r.isActive;
    new bootstrap.Modal(document.getElementById('defaultResponseModal')).show();
  }
  async function saveDefaultResponse() {
    const form = document.getElementById('defaultResponseForm');
    const fd = new FormData(form);
    const data = { name: fd.get('name'), message: fd.get('message'), priority: parseInt(fd.get('priority')), isActive: fd.get('isActive') === 'on' };
    const id = fd.get('id'); const isEdit = id && id.trim();
    try {
      const res = await fetch(isEdit ? `/api/default-responses/${id}` : '/api/default-responses', {
        method: isEdit ? 'PUT' : 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(data)
      });
      const result = await res.json();
      if (result.success) { bootstrap.Modal.getInstance(document.getElementById('defaultResponseModal')).hide(); loadDefaultResponses(); showToast(result.message, 'success'); }
      else showToast('Lỗi: ' + result.error, 'danger');
    } catch(e) { showToast('Lỗi kết nối', 'danger'); }
  }
  async function deleteDefaultResponse(id) {
    if (!confirm('Xóa câu trả lời mặc định này?')) return;
    try {
      const res = await fetch(`/api/default-responses/${id}`, { method:'DELETE' });
      const result = await res.json();
      if (result.success) { loadDefaultResponses(); showToast(result.message, 'success'); }
      else showToast('Lỗi: ' + result.error, 'danger');
    } catch(e) { showToast('Lỗi kết nối', 'danger'); }
  }

  function escapeHtml(text) { const d = document.createElement('div'); d.textContent = text; return d.innerHTML; }

  function downloadTemplate() { window.open('/api/download/excel-template', '_blank'); }

  // ═══════════════════════════════════════════════════════════════
  // LAYOUT SWITCHER (QNA)
  // ═══════════════════════════════════════════════════════════════
  document.addEventListener('DOMContentLoaded', function() {
    const container = document.getElementById('qnaContainer');
    if (!container) return;
    const savedLayout = localStorage.getItem('qnaLayout') || 'auto';

    function applyLayout(layout) {
      container.className = 'questions-grid' + (layout !== 'auto' ? ' grid-' + layout : '');
      document.querySelectorAll('.layout-option').forEach(b => b.classList.remove('active'));
      const active = document.querySelector('.layout-option[data-layout="' + layout + '"]');
      if (active) active.classList.add('active');
    }
    applyLayout(savedLayout);

    document.querySelectorAll('.layout-option').forEach(btn => {
      btn.addEventListener('click', function() {
        const layout = this.dataset.layout;
        localStorage.setItem('qnaLayout', layout);
        applyLayout(layout);
      });
    });
  });

  // LAYOUT SWITCHER (Pending)
  document.addEventListener('DOMContentLoaded', function() {
    const container = document.getElementById('pendingContainer');
    if (!container) return;
    const saved = localStorage.getItem('pendingLayout') || 'auto';

    function apply(layout) {
      container.className = 'pending-grid' + (layout !== 'auto' ? ' grid-' + layout : '');
      document.querySelectorAll('.pending-layout-option').forEach(b => b.classList.remove('active'));
      const a = document.querySelector('.pending-layout-option[data-layout="' + layout + '"]');
      if (a) a.classList.add('active');
    }
    apply(saved);

    document.querySelectorAll('.pending-layout-option').forEach(btn => {
      btn.addEventListener('click', function() {
        const l = this.dataset.layout;
        localStorage.setItem('pendingLayout', l);
        apply(l);
      });
    });
  });

  // ═══════════════════════════════════════════════════════════════
  // REAL-TIME SEARCH & FILTER
  // ═══════════════════════════════════════════════════════════════
  document.addEventListener('DOMContentLoaded', function() {
    const sourceFilter = document.getElementById('sourceFilter');
    const searchInput = document.getElementById('searchInput');
    const clearSearchBtn = document.getElementById('clearSearchBtn');
    const filterStatus = document.getElementById('filterStatus');
    const filterStatusText = document.getElementById('filterStatusText');
    const qnaContainer = document.getElementById('qnaContainer');
    const qnaPagination = document.getElementById('qnaPagination');
    const qnaPageInfo = document.getElementById('qnaPageInfo');
    const loadingIndicator = document.getElementById('searchLoadingIndicator');
    const clearBtn = document.getElementById('clearSearchBtn');

    if (!sourceFilter || !searchInput || !qnaContainer) return;

    let currentPage = parseInt('<%= page %>') || 1;
    let currentPageSize = parseInt('<%= pageSize %>') || 6;

    const sourceBadgeConfig = {
      'admin': { icon: '👤', text: 'Admin', cls: 'src-admin' },
      'ai_generated': { icon: '🤖', text: 'AI tạo', cls: 'src-ai_generated' },
      'ai_improved': { icon: '💡', text: 'AI cải thiện', cls: 'src-ai_improved' },
      'import': { icon: '📊', text: 'Import', cls: 'src-import' },
      'database': { icon: '💾', text: 'Database', cls: 'src-database' }
    };

    function escapeHtmlSafe(text) { const d = document.createElement('div'); d.textContent = text; return d.innerHTML; }

    function highlightText(text, term) {
      if (!term) return escapeHtmlSafe(text);
      const escaped = escapeHtmlSafe(text);
      const eTerm = term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      return escaped.replace(new RegExp('(' + eTerm + ')', 'gi'), '<mark class="bg-warning text-dark px-1 rounded">$1</mark>');
    }

    function renderQuestionCard(q, index, page, pageSize, searchTerm) {
      const source = q.source || 'database';
      const badge = sourceBadgeConfig[source] || sourceBadgeConfig['database'];
      const num = index + 1 + (page - 1) * pageSize;
      const qHtml = highlightText(q.question, searchTerm);
      let answersViewHtml = '';
      if (q.answers && q.answers.length > 0) {
        q.answers.slice(0, 2).forEach(a => { answersViewHtml += `<div class="q-answer">${highlightText(a, searchTerm)}</div>`; });
        if (q.answers.length > 2) answersViewHtml += `<div class="q-answer-more">+ ${q.answers.length - 2} khác</div>`;
      } else {
        answersViewHtml = '<div class="q-answer" style="border-left-color:var(--warning);"><i class="fa fa-exclamation-triangle text-warning me-1"></i> Chưa có trả lời</div>';
      }
      let editAnswersHtml = '';
      if (q.answers && q.answers.length > 0) {
        q.answers.forEach((a, i) => {
          editAnswersHtml += `<div class="answer-item mb-2"><div class="d-flex align-items-start gap-2"><div class="flex-grow-1"><label class="form-label small text-muted">Trả lời ${i+1}:</label><textarea name="answers[]" class="form-control auto-expand" rows="2">${escapeHtmlSafe(a)}</textarea></div><button type="button" class="btn btn-outline-danger btn-sm ms-1 remove-answer"><i class="fa fa-times"></i></button></div></div>`;
        });
      } else {
        editAnswersHtml = '<div class="answer-item mb-2"><div class="d-flex align-items-start gap-2"><div class="flex-grow-1"><label class="form-label small text-muted">Trả lời 1:</label><textarea name="answers[]" class="form-control auto-expand" rows="2" placeholder="Nhập câu trả lời..."></textarea></div><button type="button" class="btn btn-outline-danger btn-sm ms-1 remove-answer"><i class="fa fa-times"></i></button></div></div>';
      }

      return `
      <div class="q-card" data-question-id="${q._id}" data-index="${index}" style="animation:fadeInUp 0.3s ease ${index*0.04}s both;">
        <div class="q-header">
          <span class="q-num">#${num}</span>
          <span class="q-source ${badge.cls}">${badge.icon} ${badge.text}</span>
        </div>
        <div id="view-mode-${q._id}">
          <div class="q-body">
            <div class="q-question"><i class="fa fa-question-circle text-success me-1"></i> ${qHtml}</div>
            ${answersViewHtml}
          </div>
          <div class="q-footer">
            <button type="button" class="btn btn-outline-primary btn-sm" onclick="toggleEditMode('${q._id}')"><i class="fa fa-edit"></i> Sửa</button>
            <form action="/admin/delete/${q._id}?page=${page}&tab=qna" method="POST" class="d-inline">
              <button class="btn btn-outline-danger btn-sm" type="submit" onclick="return confirm('Xóa?')"><i class="fa fa-trash"></i></button>
            </form>
          </div>
        </div>
        <div id="edit-mode-${q._id}" style="display:none;">
          <div class="q-edit" style="display:block;">
            <form action="/admin/edit/${q._id}?page=${page}&tab=qna" method="POST" class="edit-form">
              <div class="mb-2"><label class="form-label text-success">Câu hỏi:</label><input type="text" name="question" class="form-control" value="${escapeHtmlSafe(q.question)}" required></div>
              <div class="mb-2"><label class="form-label text-primary">Trả lời:</label><div id="answers-container-${q._id}" class="answers-container">${editAnswersHtml}</div>
                <button type="button" class="btn btn-outline-primary btn-sm add-answer-btn" data-id="${q._id}"><i class="fa fa-plus"></i> Thêm</button>
              </div>
              <div class="d-flex gap-2 justify-content-end mt-2">
                <button type="button" class="btn btn-secondary btn-sm" onclick="toggleEditMode('${q._id}')"><i class="fa fa-times"></i> Hủy</button>
                <button type="submit" class="btn btn-success btn-sm"><i class="fa fa-save"></i> Lưu</button>
              </div>
            </form>
          </div>
        </div>
      </div>`;
    }

    function renderPagination(page, totalPages) {
      if (!qnaPagination) return;
      if (totalPages <= 1) { qnaPagination.innerHTML = ''; return; }
      let s = Math.max(1, page-2), e = Math.min(totalPages, page+2);
      let h = '<nav><ul class="pagination justify-content-center">';
      h += `<li class="page-item ${page===1?'disabled':''}"><a class="page-link" href="#" data-page="${page-1}">&laquo;</a></li>`;
      if (s>1) { h += '<li class="page-item"><a class="page-link" href="#" data-page="1">1</a></li>'; if(s>2) h += '<li class="page-item disabled"><span class="page-link">...</span></li>'; }
      for (let i=s;i<=e;i++) h += `<li class="page-item ${page===i?'active':''}"><a class="page-link" href="#" data-page="${i}">${i}</a></li>`;
      if (e<totalPages) { if(e<totalPages-1) h += '<li class="page-item disabled"><span class="page-link">...</span></li>'; h += `<li class="page-item"><a class="page-link" href="#" data-page="${totalPages}">${totalPages}</a></li>`; }
      h += `<li class="page-item ${page===totalPages?'disabled':''}"><a class="page-link" href="#" data-page="${page+1}">&raquo;</a></li></ul></nav>`;
      qnaPagination.innerHTML = h;
      qnaPagination.querySelectorAll('a[data-page]').forEach(l => {
        l.addEventListener('click', function(ev) { ev.preventDefault(); const p = parseInt(this.dataset.page); if (p>=1&&p<=totalPages) { currentPage=p; fetchQuestions(); } });
      });
    }

    function updateSourceStats(stats) {
      if (!stats) return;
      const total = (stats.admin||0)+(stats.ai_generated||0)+(stats.ai_improved||0)+(stats.import||0)+(stats.database||0);
      const el = id => document.getElementById(id);
      if (el('statAdmin')) el('statAdmin').textContent = stats.admin||0;
      if (el('statAdminPct')) el('statAdminPct').textContent = '👤 Admin tạo · '+(total>0?((stats.admin/total)*100).toFixed(1):'0.0')+'%';
      if (el('statAI')) el('statAI').textContent = (stats.ai_generated||0)+(stats.ai_improved||0);
      if (el('statAIDetail')) el('statAIDetail').innerHTML = `🤖 ${stats.ai_generated||0} tạo mới · 💡 ${stats.ai_improved||0} cải thiện`;
      if (el('statOther')) el('statOther').textContent = (stats.import||0)+(stats.database||0);
      if (el('statOtherDetail')) el('statOtherDetail').innerHTML = `📊 ${stats.import||0} Excel · 💾 ${stats.database||0} cũ`;
    }

    function updateFilterStatus() {
      const hasF = sourceFilter.value !== 'all' || searchInput.value.trim();
      if (hasF) {
        let t = '';
        if (sourceFilter.value !== 'all') t = sourceFilter.options[sourceFilter.selectedIndex].text;
        if (searchInput.value.trim()) { if (t) t += ' · '; t += '"' + searchInput.value.trim() + '"'; }
        filterStatusText.textContent = t;
        filterStatus.classList.add('visible');
      } else { filterStatus.classList.remove('visible'); }

      // Show/hide clear button
      if (clearBtn) clearBtn.style.display = searchInput.value ? 'block' : 'none';
    }

    let fetchCtrl = null;
    async function fetchQuestions() {
      if (fetchCtrl) fetchCtrl.abort();
      fetchCtrl = new AbortController();
      const source = sourceFilter.value;
      const search = searchInput.value.trim();
      if (loadingIndicator) loadingIndicator.style.display = 'inline-block';
      qnaContainer.style.opacity = '0.5';
      updateFilterStatus();
      try {
        const params = new URLSearchParams({ source, search, page: currentPage, limit: currentPageSize });
        const res = await fetch('/api/questions/search?' + params, { signal: fetchCtrl.signal });
        const data = await res.json();
        if (!data.success) return;
        if (qnaPageInfo) qnaPageInfo.innerHTML = `Trang ${data.page}/${data.totalPages||1} · Tổng <strong>${data.total}</strong> câu hỏi` + ((source!=='all'||search) ? ' <span class="filter-badge visible" style="display:inline-flex;">🔍 Đang lọc</span>' : '');
        if (data.questions.length === 0) {
          qnaContainer.innerHTML = '<div class="no-results"><i class="fa fa-search d-block"></i><h5>Không tìm thấy</h5><p>Thử thay đổi bộ lọc hoặc từ khóa</p></div>';
        } else {
          qnaContainer.innerHTML = data.questions.map((q, i) => renderQuestionCard(q, i, data.page, currentPageSize, search)).join('');
          // Rebind dynamic add-answer buttons
          qnaContainer.querySelectorAll('.add-answer-btn').forEach(btn => {
            btn.addEventListener('click', function() {
              const id = this.dataset.id;
              const con = document.getElementById('answers-container-' + id); if (!con) return;
              const cnt = con.querySelectorAll('.answer-item').length + 1;
              const item = document.createElement('div'); item.className = 'answer-item mb-2';
              item.innerHTML = `<div class="d-flex align-items-start gap-2"><div class="flex-grow-1"><label class="form-label small text-muted">Trả lời ${cnt}:</label><textarea name="answers[]" class="form-control auto-expand" rows="2" placeholder="Nhập câu trả lời..."></textarea></div><button type="button" class="btn btn-outline-danger btn-sm ms-1 remove-answer"><i class="fa fa-times"></i></button></div>`;
              con.appendChild(item);
              item.querySelector('.remove-answer').addEventListener('click', () => item.remove());
            });
          });
          qnaContainer.querySelectorAll('.remove-answer').forEach(btn => {
            btn.addEventListener('click', function() { const item = this.closest('.answer-item'); if (item) item.remove(); });
          });
        }
        renderPagination(data.page, data.totalPages);
        updateSourceStats(data.sourceStats);
      } catch(e) { if (e.name === 'AbortError') return; }
      finally { if (loadingIndicator) loadingIndicator.style.display = 'none'; qnaContainer.style.opacity = '1'; }
    }

    let searchTimeout;
    sourceFilter.addEventListener('change', () => { currentPage = 1; fetchQuestions(); });
    searchInput.addEventListener('input', () => { clearTimeout(searchTimeout); searchTimeout = setTimeout(()=>{ currentPage=1; fetchQuestions(); }, 400); updateFilterStatus(); });
    clearSearchBtn.addEventListener('click', () => { searchInput.value = ''; currentPage = 1; fetchQuestions(); });
    searchInput.addEventListener('keypress', e => { if (e.key === 'Enter') { e.preventDefault(); clearTimeout(searchTimeout); currentPage=1; fetchQuestions(); } });

    // Initial filter status
    updateFilterStatus();
  });

  // ═══════════════════════════════════════════════════════════════
  // TOAST SYSTEM
  // ═══════════════════════════════════════════════════════════════
  const toastContainer = document.createElement('div');
  toastContainer.className = 'toast-container';
  document.body.appendChild(toastContainer);

  function showToast(message, type = 'success', duration = 5000) {
    const icons = { success: 'fa-check-circle text-success', info: 'fa-info-circle text-info', warning: 'fa-exclamation-triangle text-warning', danger: 'fa-times-circle text-danger' };
    const titles = { success: 'Thành công', info: 'Thông báo', warning: 'Cảnh báo', danger: 'Lỗi' };
    const toast = document.createElement('div');
    toast.className = 'custom-toast toast-' + type;
    toast.innerHTML = `
      <div class="toast-header"><i class="fa ${icons[type]||icons.info} me-2"></i><strong class="me-auto">${titles[type]||titles.info}</strong><button type="button" class="btn-close" onclick="this.closest('.custom-toast').remove()"></button></div>
      <div class="toast-body">${message}</div>`;
    toastContainer.appendChild(toast);
    setTimeout(() => { toast.style.animation = 'slideOut 0.3s ease'; setTimeout(()=>toast.remove(), 300); }, duration);
  }

  // Legacy showAlert for compatibility
  function showAlert(message, type) { showToast(message, type || 'info'); }

  // ═══════════════════════════════════════════════════════════════
  // AUTO-REFRESH BADGES
  // ═══════════════════════════════════════════════════════════════
  let lastTotalQuestions = <%= totalQuestions %>;
  let lastTotalPending = <%= totalPending %>;
  let lastNewToday = <%= newQuestionsToday %>;

  async function refreshBadges() {
    try {
      const res = await fetch('/api/admin/stats');
      const data = await res.json();
      if (!data.success) return;

      // Update sidebar stats
      const sTotal = document.getElementById('sidebarStatTotal');
      const sPending = document.getElementById('sidebarStatPending');
      const sToday = document.getElementById('sidebarStatToday');
      if (sTotal) sTotal.textContent = data.totalQuestions;
      if (sPending) sPending.textContent = data.totalPending;
      if (sToday) sToday.textContent = data.newQuestionsToday;

      // Update sidebar nav badges
      const qnaBadge = document.querySelector('#qna-tab .nav-badge');
      if (qnaBadge) qnaBadge.textContent = data.totalQuestions;
      const pendingBadge = document.querySelector('#pending-tab .nav-badge');
      if (pendingBadge) {
        pendingBadge.textContent = data.totalPending;
        if (data.totalPending > lastTotalPending) {
          showToast(`Có ${data.totalPending - lastTotalPending} câu hỏi mới cần trả lời!`, 'warning');
          pendingBadge.classList.add('pulse-badge');
        }
      }

      if (data.newQuestionsToday > lastNewToday) {
        showToast(`AI đã thêm ${data.newQuestionsToday - lastNewToday} câu hỏi mới!`, 'info');
      }

      lastTotalQuestions = data.totalQuestions;
      lastTotalPending = data.totalPending;
      lastNewToday = data.newQuestionsToday;
    } catch(e) { console.error('refreshBadges error', e); }
  }
  setInterval(refreshBadges, 30000);

  // Welcome toasts
  <% if (newQuestionsToday > 0) { %>
  setTimeout(() => showToast('<%= newQuestionsToday %> câu hỏi mới hôm nay bởi AI!', 'info', 6000), 1000);
  <% } %>
  <% if (totalPending > 0) { %>
  setTimeout(() => showToast('<%= totalPending %> câu hỏi đang chờ trả lời!', 'warning', 6000), 2000);
  <% } %>
  </script>
</body>
</html>
