<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Import câu hỏi từ Excel</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body>
  <div class="container mt-4">
    <h2>Import câu hỏi & trả lời từ file Excel</h2>
    <form action="/admin/import" method="POST" enctype="multipart/form-data">
      <div class="mb-3">
        <label for="excelFile" class="form-label">Chọn file Excel (.xlsx, .xls)</label>
        <input type="file" class="form-control" id="excelFile" name="excelFile" accept=".xlsx,.xls" required>
      </div>
      <button type="submit" class="btn btn-success">Import</button>
      <a href="/admin" class="btn btn-secondary">Quay lại</a>
    </form>
    <div class="mt-3">
      <b>Mẫu file Excel:</b>
      <table class="table table-bordered w-50">
        <tr><th>Câu hỏi</th><th>Trả lời</th></tr>
        <tr><td>xin chào</td><td>Chào bạn! Tôi có thể giúp gì cho bạn?</td></tr>
        <tr><td>bạn là ai</td><td>Tôi là chatbot AI...</td></tr>
      </table>
    </div>
  </div>
</body>
</html> 