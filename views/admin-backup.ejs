    function saveThresholds() {
      const highInput = document.getElementById('scoreThresholdHighInput');
      const lowInput = document.getElementById('scoreThresholdLowInput');
      if (!highInput || !lowInput) return;
      
      const scoreThresholdHigh = parseFloat(highInput.value);
      const scoreThresholdLow = parseFloat(lowInput.value);
      
      if (isNaN(scoreThresholdHigh) || isNaN(scoreThresholdLow)) {
        alert('Vui lòng nhập giá trị số hợp lệ');
        return;
      }
      
      if (scoreThresholdHigh < 0 || scoreThresholdHigh > 1 || scoreThresholdLow < 0 || scoreThresholdLow > 1) {
        alert('Giá trị threshold phải trong khoảng 0-1');
        return;
      }
      
      if (scoreThresholdLow >= scoreThresholdHigh) {
        alert('Ngưỡng thấp phải nhỏ hơn ngưỡng cao');
        return;
      }
      
      fetch('/api/settings/thresholds', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ scoreThresholdHigh, scoreThresholdLow })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          const statusElement = document.getElementById('thresholdStatus');
          if (statusElement) {
            statusElement.textContent = `Cao: ${scoreThresholdHigh} | Thấp: ${scoreThresholdLow}`;
            statusElement.className = 'api-key-display';
            statusElement.style.color = '#28a745';
          }
          const formElement = document.getElementById('thresholdForm');
          if (formElement) {
            const collapseInstance = bootstrap.Collapse.getInstance(formElement);
            if (collapseInstance) {
              collapseInstance.hide();
            }
          }
          alert('Đã lưu threshold settings thành công!');
        } else {
          alert('Lỗi khi lưu threshold settings: ' + (data.error || data.message));
        }
      })
      .catch(error => {
        alert('Lỗi kết nối khi lưu threshold settings');
      });
    }
    
