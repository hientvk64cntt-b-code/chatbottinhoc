      const input = document.getElementById('testInput').value;
      const checkbox = document.getElementById('testCheck').checked;
      
      alert('Test Input: ' + input + '\nCheckbox: ' + (checkbox ? 'Checked' : 'Unchecked'));
    }
    
    function refreshStatus() {
      alert('Status refreshed!');
    }
    
    // Toggle edit form
    function toggleEditForm(formId) {
      const formElement = document.getElementById(formId);
      if (formElement) {
        const collapseInstance = bootstrap.Collapse.getInstance(formElement);
        if (collapseInstance) {
          collapseInstance.toggle();
        } else {
          new bootstrap.Collapse(formElement).toggle();
        }
      }
    }
    
    function loadAvailableModels() {
      const modelsList = document.getElementById('modelsList');
      const loadBtn = document.getElementById('loadModelsBtn');
      
      if (!modelsList || !loadBtn) return;
      
      loadBtn.textContent = 'Đang tải...';
      loadBtn.disabled = true;
      
      fetch('/api/models/available')
        .then(response => response.json())
        .then(data => {
          console.log('📊 Models API response:', data);
          
          if (data.success && data.models && data.models.length > 0) {
            modelsList.innerHTML = '';
            
            data.models.forEach(model => {
              const modelItem = document.createElement('div');
              modelItem.className = 'model-item';
              modelItem.innerHTML = `
                <span class="model-name">${model}</span>
                <span class="model-status">Available</span>
              `;
              
              modelItem.addEventListener('click', function() {
                selectModel(model);
              });
              
              modelsList.appendChild(modelItem);
            });
            
            console.log(`✅ Loaded ${data.models.length} models successfully`);
          } else {
            const errorMsg = data.error || 'Không thể tải danh sách model';
            modelsList.innerHTML = `<div class="text-danger">❌ ${errorMsg}</div>`;
            console.error('❌ Failed to load models:', errorMsg);
          }
        })
        .catch(error => {
          modelsList.innerHTML = '<div class="text-danger">Lỗi kết nối khi tải model</div>';
        })
        .finally(() => {
          loadBtn.textContent = 'Tải danh sách';
          loadBtn.disabled = false;
        });
    }
    
    function selectModel(modelName) {
      // Remove previous selection
      document.querySelectorAll('.model-item').forEach(item => {
        item.classList.remove('selected');
      });
      
      // Add selection to clicked item
      event.target.closest('.model-item').classList.add('selected');
      
      // Save the selected model
      fetch('/api/settings/current-model', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ model: modelName })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          // Update the current model display
          const modelElement = document.getElementById('currentModel');
          if (modelElement) {
            modelElement.textContent = modelName;
            modelElement.className = 'api-key-display';
            modelElement.style.color = '#28a745';
          }
          
          // Close the model selection form
          toggleEditForm('modelSelectForm');
          
          // Show success message
          alert(`Đã chọn model: ${modelName}`);
        } else {
          alert('Lỗi khi lưu model: ' + data.message);
        }
      })
      .catch(error => {
        alert('Lỗi kết nối khi lưu model');
      });
    }
    
    // Test Gemini API connection for model selection
    function testGeminiApiForModels() {
      const testBtn = document.getElementById('testApiBtn');
      if (!testBtn) return;
      
      testBtn.textContent = 'Đang test...';
      testBtn.disabled = true;
      
      fetch('/api/test/gemini')
        .then(response => response.json())
        .then(data => {
          console.log('📊 Gemini API test result:', data);
          
          if (data.success) {
            const workingModels = data.probe?.filter(p => p.ok) || [];
            const modelList = workingModels.map(m => m.model).join('\n• ');
            
            alert(`✅ Gemini API hoạt động tốt!\n\n` +
                  `Status: ${data.status?.status || 'Unknown'}\n` +
                  `Working Models (${workingModels.length}):\n• ${modelList || 'None'}`);
          } else {
            const failedModels = data.probe?.filter(p => !p.ok) || [];
            const errorList = failedModels.slice(0, 3).map(m => `${m.model}: ${m.error}`).join('\n• ');
            
            alert(`❌ Gemini API test failed!\n\n` +
                  `Error: ${data.error}\n` +
                  `Status: ${data.status?.status || 'Unknown'}\n` +
                  `Failed Models:\n• ${errorList || 'None'}`);
          }
        })
        .catch(error => {
          console.error('Error testing Gemini API:', error);
          alert('❌ Lỗi kết nối khi test Gemini API: ' + error.message);
        })
        .finally(() => {
          testBtn.textContent = 'Test API';
          testBtn.disabled = false;
        });
    }
    
    // Reload API key from database
    function reloadApiKey() {
      const reloadBtn = document.getElementById('reloadApiBtn');
      if (!reloadBtn) return;
      
      reloadBtn.textContent = 'Đang reload...';
      reloadBtn.disabled = true;
      
      fetch('/api/settings/gemini-api-key')
        .then(response => response.json())
        .then(data => {
          console.log('📊 API Key reload result:', data);
          
          if (data.success && data.value) {
            // Trigger API key reload on server
            fetch('/api/settings/gemini-api-key', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify({ value: data.value })
            })
            .then(response => response.json())
            .then(result => {
              if (result.success) {
                alert('✅ API Key đã được reload thành công!\n\nHãy thử "Test API" lại.');
              } else {
                alert('❌ Lỗi khi reload API Key: ' + result.error);
              }
            })
            .catch(error => {
              console.error('Error reloading API key:', error);
              alert('❌ Lỗi kết nối khi reload API Key: ' + error.message);
            });
          } else {
            alert('❌ Không tìm thấy API Key trong database!\n\nHãy cấu hình API Key trước.');
          }
        })
        .catch(error => {
          console.error('Error fetching API key:', error);
          alert('❌ Lỗi kết nối khi lấy API Key: ' + error.message);
        })
        .finally(() => {
          reloadBtn.textContent = 'Reload API Key';
          reloadBtn.disabled = false;
        });
    }
    
    // Force switch to gemini-2.0-flash (for quota exceeded)
    function forceSwitchToFlash() {
      if (!confirm('Bạn có chắc chắn muốn chuyển sang model gemini-2.0-flash? (Để tránh quota exceeded)')) {
        return;
      }
      
      const currentModel = document.getElementById('currentModel').textContent;
      
      fetch('/api/models/force-switch', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ 
          fromModel: currentModel, 
          toModel: 'models/gemini-2.0-flash' 
        })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          // Update the current model display
          const modelElement = document.getElementById('currentModel');
          if (modelElement) {
            modelElement.textContent = 'models/gemini-2.0-flash';
            modelElement.className = 'api-key-display';
            modelElement.style.color = '#28a745';
          }
          
          // Close the model selection form
          toggleEditForm('modelSelectForm');
          
          alert('✅ Đã chuyển sang model gemini-2.0-flash thành công!');
        } else {
          alert('❌ Lỗi khi chuyển model: ' + data.error);
        }
      })
      .catch(error => {
        console.error('Error force switching model:', error);
        alert('❌ Lỗi khi chuyển model: ' + error.message);
      });
    }
  </script>
  <script>
    // Custom Tab System
    document.addEventListener('DOMContentLoaded', function() {
      const url = new URL(window.location.href);
      const currentTab = url.searchParams.get('tab') || 'qna';
      console.log('Current tab from URL:', currentTab);
      
      // Initialize tabs
      initializeTabs();
      
      // Tab click handlers
      document.getElementById('qna-tab').addEventListener('click', function() {
        switchTab('qna');
      });
      
      document.getElementById('pending-tab').addEventListener('click', function() {
        switchTab('pending');
      });
      
      document.getElementById('default-responses-tab').addEventListener('click', function() {
        switchTab('default-responses');
      });
      
      document.getElementById('import-tab').addEventListener('click', function() {
        switchTab('import');
      });
      
      document.getElementById('settings-tab').addEventListener('click', function() {
        switchTab('settings');
      });
      
      function initializeTabs() {
        // Hide all tab panes
      document.querySelectorAll('.tab-pane').forEach(pane => {
          pane.classList.remove('active');
        });
        
        // Remove active from all nav links
        document.querySelectorAll('.nav-link').forEach(link => {
          link.classList.remove('active');
        });
        
        // Show current tab
        const activeTab = document.getElementById(currentTab);
        const activeNavLink = document.getElementById(currentTab + '-tab');
        
        if (activeTab) {
          activeTab.classList.add('active');
        }
        if (activeNavLink) {
          activeNavLink.classList.add('active');
        }
        
        // Load default responses if we're on that tab
        if (currentTab === 'default-responses') {
          console.log('Page loaded with default-responses tab, loading data...');
          setTimeout(() => {
            if (typeof loadDefaultResponses === 'function') {
              loadDefaultResponses();
            }
          }, 500);
        }
      }
      
      function switchTab(tabName) {
        const url = new URL(window.location.href);
        url.searchParams.set('tab', tabName);
        
        // Clear pagination params when switching tabs
        if (tabName === 'settings') {
        url.searchParams.delete('page');
        url.searchParams.delete('pagePending');
        }
        
        // Load default responses when switching to that tab
        if (tabName === 'default-responses') {
          console.log('Switching to default-responses tab, loading data...');
          setTimeout(() => {
            if (typeof loadDefaultResponses === 'function') {
              loadDefaultResponses();
            }
          }, 100);
        }
        
        window.location.href = url.toString();
      }
    });
    // Xác nhận khi ấn nút Lưu
    document.querySelectorAll('form[action^="/admin/edit/"]').forEach(function(form) {
      form.addEventListener('submit', function(e) {
        // Debug: log form data before submit
        const formData = new FormData(form);
        const answers = [];
        for (let [key, value] of formData.entries()) {
          if (key === 'answers[]') {
            answers.push(value);
          }
        }
        console.log('Form submit - answers array:', answers);
        console.log('Form submit - answers length:', answers.length);
        
        if (!confirm('Bạn có chắc chắn muốn lưu thay đổi này?')) {
          e.preventDefault();
        }
      });
    });

    // Xác nhận khi ấn nút Xóa - sử dụng event delegation để tránh duplicate
    document.addEventListener('submit', function(e) {
      if (e.target && e.target.action && e.target.action.includes('/admin/delete/')) {
        if (!confirm('Bạn chắc chắn muốn xóa?')) {
          e.preventDefault();
          return false;
        }
      }
    });

    // Cảnh báo khi rời khỏi vùng chỉnh sửa nếu có thay đổi chưa lưu cho tất cả các form nhập liệu
    document.querySelectorAll('form').forEach(function(form) {
      let isDirty = false;
      let inputs = form.querySelectorAll('input, textarea');
      let initialValues = {};
      inputs.forEach(function(input) {
        initialValues[input.name] = input.value;
        input.addEventListener('input', function() {
          isDirty = false;
          for (let inp of inputs) {
            if (inp.value !== initialValues[inp.name]) {
              isDirty = true;
              break;
            }
          }
        });
      });
      // Cảnh báo khi reload/tab close
      window.addEventListener('beforeunload', function (e) {
        if (isDirty) {
          e.preventDefault();
          e.returnValue = '';
          return '';
        }
      });
      // Reset isDirty khi submit
      form.addEventListener('submit', function() {
        isDirty = false;
        // Cập nhật lại initialValues sau khi submit
        inputs.forEach(function(input) {
          initialValues[input.name] = input.value;
        });
      });
      // Cảnh báo khi click ra ngoài form
      document.addEventListener('mousedown', function(e) {
        if (isDirty && !form.contains(e.target)) {
          let confirmLeave = confirm('Bạn có muốn lưu thay đổi trước khi rời khỏi vùng chỉnh sửa không?');
          if (!confirmLeave) {
            isDirty = false;
            // Reset lại giá trị input về ban đầu
            inputs.forEach(function(input) {
              input.value = initialValues[input.name];
            });
          } else {
            form.submit();
            isDirty = false;
          }
        }
      });
    });
    // Cảnh báo khi click ra ngoài form trả lời nhanh nếu có thay đổi chưa lưu
    // Tự động co giãn textarea
    function autoExpandTextarea(textarea) {
      textarea.style.height = 'auto';
      textarea.style.height = (textarea.scrollHeight) + 'px';
    }
    document.querySelectorAll('.auto-expand').forEach(function(textarea) {
      textarea.addEventListener('input', function() {
        autoExpandTextarea(textarea);
      });
      autoExpandTextarea(textarea);
    });

    // Xác nhận khi lưu/xóa, xác nhận khi click ra ngoài nếu có thay đổi chưa lưu
    // Cảnh báo khi sửa câu hỏi/đáp án ở tab Chờ trả lời
    document.querySelectorAll('.pending-edit-form').forEach(function(form) {
      let isDirty = false;
      let questionTextarea = form.querySelector('textarea[name="question"]');
      let answerTextarea = form.querySelector('textarea[name="answer"]');
      if (!questionTextarea || !answerTextarea) return;
      let initialQuestion = questionTextarea.value;
      let initialAnswer = answerTextarea.value;
      function checkDirty() {
        isDirty = (questionTextarea.value !== initialQuestion) || (answerTextarea.value !== initialAnswer);
      }
      questionTextarea.addEventListener('input', function() {
        checkDirty();
        autoExpandTextarea(questionTextarea);
      });
      answerTextarea.addEventListener('input', function() {
        checkDirty();
        autoExpandTextarea(answerTextarea);
      });
      // Lưu khi nhấn Enter trong textarea trả lời
      answerTextarea.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          if (answerTextarea.value.trim() !== '') {
            form.requestSubmit();
          }
        }
      });
      // Cảnh báo khi click ra ngoài vùng chỉnh sửa hoặc khi click nút lưu/xóa
      function handleOutsideClick(e) {
        if (isDirty && !form.contains(e.target)) {
          let confirmLeave = confirm('Bạn có muốn lưu thay đổi trước khi rời khỏi vùng chỉnh sửa không?');
          if (confirmLeave) {
            if (answerTextarea.value.trim() !== '') {
              form.requestSubmit();
            } else {
              // Không cho lưu nếu chưa nhập câu trả lời
              alert('Bạn cần nhập câu trả lời để lưu và chuyển sang tab Đã có trả lời.');
            }
          } else {
            isDirty = false;
            questionTextarea.value = initialQuestion;
            answerTextarea.value = initialAnswer;
            autoExpandTextarea(questionTextarea);
            autoExpandTextarea(answerTextarea);
          }
        }
      }
      document.addEventListener('mousedown', handleOutsideClick);
      // Xác nhận khi submit lưu
      form.addEventListener('submit', function(e) {
        if (isDirty) {
          if (!confirm('Bạn có chắc chắn muốn lưu thay đổi này?')) {
            e.preventDefault();
            return;
          }
        }
        // Chỉ cho submit nếu đã nhập câu trả lời
        const answerTextareas = form.querySelectorAll('textarea[name^="answers"]');
        let hasAnswer = false;
        answerTextareas.forEach(textarea => {
          if (textarea.value.trim() !== '') {
            hasAnswer = true;
          }
        });
        if (!hasAnswer) {
          alert('Bạn cần nhập ít nhất một câu trả lời để lưu và chuyển sang tab Đã có trả lời.');
          e.preventDefault();
          return;
        }
        isDirty = false;
        initialQuestion = questionTextarea.value;
        initialAnswer = answerTextarea.value;
      });
      // Cảnh báo khi reload/tab close
      window.addEventListener('beforeunload', function (e) {
        if (isDirty) {
          e.preventDefault();
          e.returnValue = '';
          return '';
        }
      });
    });

    // Gắn sự kiện cho nút xóa ở bảng chờ trả lời
    document.querySelectorAll('.btn-delete-pending').forEach(function(deleteBtn) {
      deleteBtn.addEventListener('click', function(e) {
        e.preventDefault();
        if (!confirm('Bạn chắc chắn muốn xóa câu hỏi này khỏi hàng chờ?')) return;
        const id = deleteBtn.getAttribute('data-id');
        const pagePending = new URL(window.location.href).searchParams.get('pagePending') || 1;
        fetch(`/admin/delete-pending/${id}?tab=pending&pagePending=${pagePending}`, {
          method: 'POST',
          headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(res => {
          if (res.ok) window.location.reload();
          else alert('Xóa thất bại!');
        })
        .catch(() => alert('Không thể kết nối máy chủ!'));
      });
    });

    // Toggle pending edit mode
    window.togglePendingEditMode = function(questionId) {
      const viewMode = document.getElementById(`pending-view-mode-${questionId}`);
      const editMode = document.getElementById(`pending-edit-mode-${questionId}`);
      
      if (viewMode.style.display === 'none') {
        viewMode.style.display = 'block';
        editMode.style.display = 'none';
      } else {
        viewMode.style.display = 'none';
        editMode.style.display = 'block';
      }
    };

    // Add answer functionality for pending questions
    const pendingAddAnswerButtons = document.querySelectorAll('[id^="pending-add-answer-"]');
    
    pendingAddAnswerButtons.forEach(button => {
      button.addEventListener('click', function() {
        const questionId = this.id.split('-')[3];
        const container = document.getElementById(`pending-answers-container-${questionId}`);
        
        if (container) {
          const answerCount = container.querySelectorAll('.answer-item').length + 1;
          
          const answerItem = document.createElement('div');
          answerItem.className = 'answer-item mb-2';
          answerItem.innerHTML = `
            <div class="d-flex align-items-start">
              <div class="flex-grow-1">
                <label class="form-label small text-muted">Trả lời ${answerCount}:</label>
                <textarea name="answers[]" class="form-control auto-expand" rows="3" style="resize:vertical; min-height:60px;" placeholder="Nhập câu trả lời..."></textarea>
              </div>
              <button type="button" class="btn btn-outline-danger btn-sm ms-2 remove-answer" title="Xóa câu trả lời">
                <i class="fa fa-times"></i>
              </button>
            </div>
          `;
          
          container.appendChild(answerItem);
          
          // Focus on the new textarea
          const newTextarea = answerItem.querySelector('textarea');
          newTextarea.focus();
          
          // Add remove functionality to the new button
          const removeBtn = answerItem.querySelector('.remove-answer');
          removeBtn.addEventListener('click', function() {
            answerItem.remove();
            updatePendingAnswerLabels(container);
          });
        }
      });
    });

    // Update pending answer labels after adding/removing
    function updatePendingAnswerLabels(container) {
      const answerItems = container.querySelectorAll('.answer-item');
      answerItems.forEach((item, index) => {
        const label = item.querySelector('label');
        if (label) {
          label.textContent = `Trả lời ${index + 1}:`;
        }
      });
    }

  </script>
  <script>
  // Toggle edit mode
  function toggleEditMode(questionId) {
    const viewMode = document.getElementById(`view-mode-${questionId}`);
    const editMode = document.getElementById(`edit-mode-${questionId}`);
    
    if (viewMode.style.display === 'none') {
      viewMode.style.display = 'block';
      editMode.style.display = 'none';
    } else {
      viewMode.style.display = 'none';
      editMode.style.display = 'block';
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    // Add answer functionality
    const addAnswerButtons = document.querySelectorAll('[id^="add-answer-"]');
    
    addAnswerButtons.forEach(button => {
      button.addEventListener('click', function() {
        const questionId = this.id.split('-')[2];
        const container = document.getElementById(`answers-container-${questionId}`);
        
        if (container) {
          const answerCount = container.querySelectorAll('.answer-item').length + 1;
          
          const answerItem = document.createElement('div');
          answerItem.className = 'answer-item mb-2';
          answerItem.innerHTML = `
            <div class="d-flex align-items-start">
              <div class="flex-grow-1">
                <label class="form-label small text-muted">Trả lời ${answerCount}:</label>
                <textarea name="answers[]" class="form-control auto-expand" rows="3" style="resize:vertical; min-height:60px;" placeholder="Nhập câu trả lời..."></textarea>
              </div>
              <button type="button" class="btn btn-outline-danger btn-sm ms-2 remove-answer" title="Xóa câu trả lời">
                <i class="fa fa-times"></i>
              </button>
            </div>
          `;
          
          container.appendChild(answerItem);
          
          // Focus on the new textarea
          const newTextarea = answerItem.querySelector('textarea');
          newTextarea.focus();
          
          // Add remove functionality to the new button
          const removeBtn = answerItem.querySelector('.remove-answer');
          removeBtn.addEventListener('click', function() {
            answerItem.remove();
            updateAnswerLabels(container);
          });
        }
      });
    });

    // Remove answer functionality
    document.querySelectorAll('.remove-answer').forEach(button => {
      button.addEventListener('click', function() {
        const answerItem = this.closest('.answer-item');
        const container = answerItem.closest('.answers-container');
        
        // Check if this is the last answer item
        const remainingItems = container.querySelectorAll('.answer-item');
        if (remainingItems.length <= 1) {
          alert('Bạn cần ít nhất một câu trả lời!');
          return;
        }
        
        answerItem.remove();
        
        // Update labels based on container type
        if (container.id.startsWith('pending-answers-container-')) {
          updatePendingAnswerLabels(container);
        } else {
          updateAnswerLabels(container);
        }
      });
    });

    // Update answer labels after adding/removing
    function updateAnswerLabels(container) {
      const answerItems = container.querySelectorAll('.answer-item');
      answerItems.forEach((item, index) => {
        const label = item.querySelector('label');
        if (label) {
          label.textContent = `Trả lời ${index + 1}:`;
        }
      });
    }

    // Form validation for Q&A
    document.querySelectorAll('.edit-form').forEach(form => {
      form.addEventListener('submit', function(e) {
        const answers = this.querySelectorAll('textarea[name="answers[]"]');
        let hasValidAnswer = false;
        
        answers.forEach(textarea => {
          if (textarea.value.trim() !== '') {
            hasValidAnswer = true;
          }
        });
        
        if (!hasValidAnswer) {
          e.preventDefault();
          alert('Bạn cần nhập ít nhất một câu trả lời!');
          return false;
        }
        
        if (!confirm('Bạn có chắc chắn muốn lưu thay đổi này?')) {
          e.preventDefault();
          return false;
        }
      });
    });

    // Form validation for pending questions
    document.querySelectorAll('.pending-edit-form').forEach(form => {
      form.addEventListener('submit', function(e) {
        const answers = this.querySelectorAll('textarea[name="answers[]"]');
        let hasValidAnswer = false;
        
        answers.forEach(textarea => {
          if (textarea.value.trim() !== '') {
            hasValidAnswer = true;
          }
        });
        
        if (!hasValidAnswer) {
          e.preventDefault();
          alert('Bạn cần nhập ít nhất một câu trả lời!');
          return false;
        }
        
        if (!confirm('Bạn có chắc chắn muốn gửi trả lời này? Câu hỏi sẽ được chuyển sang tab "Đã có trả lời".')) {
          e.preventDefault();
          return false;
        }
      });
    });
  });
</script>

