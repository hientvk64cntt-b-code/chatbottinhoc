  <script>
    // Chat Widget JavaScript
    document.addEventListener('DOMContentLoaded', function() {
      const chatWidget = document.getElementById('chatWidget');
      const chatBody = document.getElementById('chatBody');
      const chatMessages = document.getElementById('chatMessages');
      const chatInput = document.getElementById('chatInput');
      const sendBtn = document.getElementById('sendMessage');
      const toggleBtn = document.getElementById('toggleChat');
      const currentTimeEl = document.getElementById('currentTime');
      
      let isCollapsed = true;
      
      // Update current time
      function updateTime() {
        const now = new Date();
        const time = now.toLocaleTimeString('vi-VN', { 
          hour: '2-digit', 
          minute: '2-digit' 
        });
        if (currentTimeEl) {
          currentTimeEl.textContent = time;
        }
      }
      
      updateTime();
      setInterval(updateTime, 1000);
      
      // Toggle chat widget
      toggleBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        isCollapsed = !isCollapsed;
        chatWidget.classList.toggle('expanded', !isCollapsed);
        toggleBtn.querySelector('i').className = isCollapsed ? 'fa fa-plus' : 'fa fa-minus';
      });
      
      // Send message
      function sendMessage() {
        const message = chatInput.value.trim();
        if (!message) return;
        
        // Add user message
        addMessage(message, 'user');
        chatInput.value = '';
        
        // Show typing indicator
        showTypingIndicator();
        
        // Send to backend
        fetch('/admin/test-message', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ 
            message: message,
            useAI: true // Always use AI for test
          })
        })
        .then(response => response.json())
        .then(data => {
          hideTypingIndicator();
          if (data.success && data.reply) {
            addMessage(data.reply, 'bot');
          } else {
            let errorMsg = 'Xin lỗi, có lỗi xảy ra khi xử lý tin nhắn.';
            if (data.error && data.error.includes('quota')) {
              errorMsg = '🚨 Gemini API quota exceeded! Đang sử dụng câu trả lời từ database.';
            }
            addMessage(errorMsg, 'bot');
          }
        })
        .catch(error => {
          hideTypingIndicator();
          console.error('Error:', error);
          addMessage('Xin lỗi, không thể kết nối đến server.', 'bot');
        });
      }
      
      // Add message to chat
      function addMessage(text, sender) {
        const messageDiv = document.createElement('div');
        messageDiv.className = `message ${sender}-message`;
        
        const now = new Date();
        const time = now.toLocaleTimeString('vi-VN', { 
          hour: '2-digit', 
          minute: '2-digit' 
        });
        
        let content = '';
        if (sender === 'bot') {
          content = `
            <div class="message-content">
              <i class="fa fa-robot"></i>
              <span>${text}</span>
            </div>
            <div class="message-time">${time}</div>
          `;
        } else {
          content = `
            <div class="message-content">
              <span>${text}</span>
            </div>
            <div class="message-time">${time}</div>
          `;
        }
        
        messageDiv.innerHTML = content;
        chatMessages.appendChild(messageDiv);
        
        // Scroll to bottom
        chatMessages.scrollTop = chatMessages.scrollHeight;
      }
      
      // Show typing indicator
      function showTypingIndicator() {
        const typingDiv = document.createElement('div');
        typingDiv.className = 'message bot-message typing-message';
        typingDiv.innerHTML = `
          <div class="typing-indicator">
            <i class="fa fa-robot"></i>
            <div class="typing-dots">
              <div class="typing-dot"></div>
              <div class="typing-dot"></div>
              <div class="typing-dot"></div>
            </div>
          </div>
        `;
        chatMessages.appendChild(typingDiv);
        chatMessages.scrollTop = chatMessages.scrollHeight;
      }
      
      // Hide typing indicator
      function hideTypingIndicator() {
        const typingMessage = chatMessages.querySelector('.typing-message');
        if (typingMessage) {
          typingMessage.remove();
        }
      }
      
      // Event listeners
      sendBtn.addEventListener('click', sendMessage);
      
      chatInput.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
          sendMessage();
        }
      });
      
      // Auto focus input when chat is opened
      chatWidget.addEventListener('click', function() {
        if (isCollapsed) {
          isCollapsed = false;
          chatWidget.classList.add('expanded');
          toggleBtn.querySelector('i').className = 'fa fa-minus';
          setTimeout(() => chatInput.focus(), 300);
        }
      });
    });

    // Default Responses Management
    let defaultResponses = [];

    // Load default responses when tab is shown
    const defaultResponsesTab = document.getElementById('default-responses-tab');
    if (defaultResponsesTab) {
      defaultResponsesTab.addEventListener('click', function() {
        console.log('Default responses tab clicked');
        loadDefaultResponses();
      });
    } else {
      console.error('Default responses tab not found');
    }

    // Load default responses
    async function loadDefaultResponses() {
      console.log('Loading default responses...');
      try {
        const response = await fetch('/api/default-responses');
        console.log('API response status:', response.status);
        const data = await response.json();
        console.log('API response data:', data);
        
        if (data.success) {
          defaultResponses = data.responses;
          console.log('Loaded responses:', defaultResponses);
          renderDefaultResponses();
        } else {
          console.error('API error:', data.error);
          showAlert('Lỗi khi tải danh sách câu trả lời mặc định: ' + data.error, 'danger');
        }
      } catch (error) {
        console.error('Error loading default responses:', error);
        showAlert('Lỗi khi tải danh sách câu trả lời mặc định', 'danger');
      }
    }

    // Render default responses
    function renderDefaultResponses() {
      console.log('Rendering default responses...');
      const container = document.getElementById('defaultResponsesList');
      console.log('Container found:', container);
      
      if (!container) {
        console.error('Container not found!');
        return;
      }
      
      if (defaultResponses.length === 0) {
        console.log('No responses to render, showing empty message');
        container.innerHTML = `
          <div class="col-12">
            <div class="alert alert-info text-center">
              <i class="fa fa-info-circle me-2"></i>
              Chưa có câu trả lời mặc định nào. Hãy thêm câu trả lời đầu tiên!
            </div>
          </div>
        `;
        return;
      }
      
      console.log('Rendering', defaultResponses.length, 'responses');

      container.innerHTML = defaultResponses.map(response => `
        <div class="col-md-6 col-lg-4">
          <div class="default-response-card">
            <div class="default-response-header">
              <h6 class="default-response-title">${escapeHtml(response.name)}</h6>
              <span class="default-response-priority">Ưu tiên ${response.priority}</span>
            </div>
            <div class="default-response-body">
              <div class="default-response-message">
                ${escapeHtml(response.message)}
              </div>
              <div class="d-flex justify-content-between align-items-center">
                <span class="default-response-status ${response.isActive ? 'active' : 'inactive'}">
                  <i class="fa fa-${response.isActive ? 'check-circle' : 'times-circle'}"></i>
                  ${response.isActive ? 'Đang hoạt động' : 'Tạm dừng'}
                </span>
                <div class="default-response-actions">
                  <button class="btn btn-sm btn-outline-primary" onclick="editDefaultResponse('${response._id}')">
                    <i class="fa fa-edit"></i>
                  </button>
                  <button class="btn btn-sm btn-outline-danger" onclick="deleteDefaultResponse('${response._id}')">
                    <i class="fa fa-trash"></i>
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      `).join('');
    }

    // Show add modal
    function showAddDefaultResponseModal() {
      document.getElementById('defaultResponseModalLabel').textContent = 'Thêm câu trả lời mặc định';
      document.getElementById('defaultResponseForm').reset();
      document.getElementById('defaultResponseId').value = '';
      document.getElementById('defaultResponseActive').checked = true;
      document.getElementById('defaultResponsePriority').value = '1';
      
      const modal = new bootstrap.Modal(document.getElementById('defaultResponseModal'));
      modal.show();
    }

    // Edit default response
    function editDefaultResponse(id) {
      const response = defaultResponses.find(r => r._id === id);
      if (!response) return;

      document.getElementById('defaultResponseModalLabel').textContent = 'Chỉnh sửa câu trả lời mặc định';
      document.getElementById('defaultResponseId').value = response._id;
      document.getElementById('defaultResponseName').value = response.name;
      document.getElementById('defaultResponseMessage').value = response.message;
      document.getElementById('defaultResponsePriority').value = response.priority;
      document.getElementById('defaultResponseActive').checked = response.isActive;
      
      const modal = new bootstrap.Modal(document.getElementById('defaultResponseModal'));
      modal.show();
    }

    // Save default response
    async function saveDefaultResponse() {
      const form = document.getElementById('defaultResponseForm');
      const formData = new FormData(form);
      
      const data = {
        name: formData.get('name'),
        message: formData.get('message'),
        priority: parseInt(formData.get('priority')),
        isActive: formData.get('isActive') === 'on'
      };

      const id = formData.get('id');
      const isEdit = id && id.trim() !== '';

      try {
        const url = isEdit ? `/api/default-responses/${id}` : '/api/default-responses';
        const method = isEdit ? 'PUT' : 'POST';
        
        const response = await fetch(url, {
          method: method,
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(data)
        });

        const result = await response.json();
        
        if (result.success) {
          showAlert(result.message, 'success');
          bootstrap.Modal.getInstance(document.getElementById('defaultResponseModal')).hide();
          loadDefaultResponses();
        } else {
          showAlert('Lỗi: ' + result.error, 'danger');
        }
      } catch (error) {
        console.error('Error saving default response:', error);
        showAlert('Lỗi khi lưu câu trả lời mặc định', 'danger');
      }
    }

    // Delete default response
    async function deleteDefaultResponse(id) {
      if (!confirm('Bạn chắc chắn muốn xóa câu trả lời mặc định này?')) return;

      try {
        const response = await fetch(`/api/default-responses/${id}`, {
          method: 'DELETE'
        });

        const result = await response.json();
        
        if (result.success) {
          showAlert(result.message, 'success');
          loadDefaultResponses();
        } else {
          showAlert('Lỗi: ' + result.error, 'danger');
        }
      } catch (error) {
        console.error('Error deleting default response:', error);
        showAlert('Lỗi khi xóa câu trả lời mặc định', 'danger');
      }
    }

    // Utility function to escape HTML
    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    // Show alert
    function showAlert(message, type = 'info') {
      const alertDiv = document.createElement('div');
      alertDiv.className = `alert alert-${type} alert-dismissible fade show`;
      alertDiv.innerHTML = `
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      `;
      
      const container = document.querySelector('.default-responses-container');
      container.insertBefore(alertDiv, container.firstChild);
      
      // Auto remove after 5 seconds
      setTimeout(() => {
        if (alertDiv.parentNode) {
          alertDiv.remove();
        }
      }, 5000);
    }
    
    
    // Download Excel template
    function downloadTemplate() {
      // Redirect to API endpoint to download Excel file
      window.open('/api/download/excel-template', '_blank');
      
      // Show success message
      showAlert('success', 'Đang tải xuống file Excel template...');
    }
    
    // Modern Layout Switcher for QNA Tab
    document.addEventListener('DOMContentLoaded', function() {
      const container = document.querySelector('.qna-questions-container');
      if (!container) return;
      
      // Get saved layout from localStorage
      const savedLayout = localStorage.getItem('qnaLayout') || 'auto';
      const urlParams = new URLSearchParams(window.location.search);
      const urlLayout = urlParams.get('layout');
      
      // If no layout in URL but we have one in localStorage, redirect with it
      if (!urlLayout && savedLayout !== 'auto') {
        urlParams.set('layout', savedLayout);
        window.location.href = `${window.location.pathname}?${urlParams.toString()}`;
        return;
      }
      
      // Define max items for each layout
      const maxItemsMap = {
        'auto': 6,   // 2 cột x 3 dòng
        '3': 9,      // 3 cột x 3 dòng
        '4': 16,     // 4 cột x 4 dòng
        '5': 25,     // 5 cột x 5 dòng
        '6': 36      // 6 cột x 6 dòng
      };
      
      // Apply saved layout
      function applyLayout(layout) {
        console.log('Applying layout:', layout);
        container.className = 'qna-questions-container grid-' + layout;
        
        // Remove all active classes
        document.querySelectorAll('.layout-option').forEach(btn => {
          btn.classList.remove('active');
        });
        
        // Add active to current layout
        const activeBtn = document.querySelector(`.layout-option[data-layout="${layout}"]`);
        if (activeBtn) {
          activeBtn.classList.add('active');
        }
        
        // Show all cards
        const questionCards = container.querySelectorAll('.qna-question-card');
        questionCards.forEach((card) => {
          card.style.display = 'block';
        });
        
        // Hide pagination if layout is "all"
        const pagination = document.querySelector('.pagination');
        if (layout === 'all' && pagination) {
          pagination.style.display = 'none';
        } else if (pagination) {
          pagination.style.display = 'flex';
        }
      }
      
      // Initialize with saved layout
      const activeLayout = urlLayout || savedLayout;
      applyLayout(activeLayout);
      
      // Update pagination links to include layout parameter
      const currentLayout = urlParams.get('layout') || savedLayout;
      const paginationLinks = document.querySelectorAll('.pagination a.page-link');
      paginationLinks.forEach(link => {
        if (link.href && !link.href.includes('layout=')) {
          const href = new URL(link.href);
          href.searchParams.set('layout', currentLayout);
          link.href = href.toString();
        }
      });
      
      // Handle click events
      document.querySelectorAll('.layout-option').forEach(button => {
        button.addEventListener('click', function() {
          const layout = this.dataset.layout;
          console.log('Layout button clicked:', layout);
          
          // Save to localStorage
          localStorage.setItem('qnaLayout', layout);
          
          // Reload page with layout parameter
          const url = new URL(window.location.href);
          url.searchParams.set('layout', layout);
          url.searchParams.set('page', '1'); // Reset to page 1 when changing layout
          window.location.href = url.toString();
        });
      });
    });
    
    // Modern Layout Switcher for Pending Tab
    document.addEventListener('DOMContentLoaded', function() {
      const pendingContainer = document.querySelector('#pending .pending-questions-container');
      if (!pendingContainer) return;
      
      // Get saved layout from localStorage
      const savedPendingLayout = localStorage.getItem('pendingLayout') || 'auto';
      
      // Apply saved layout
      function applyPendingLayout(layout) {
        pendingContainer.className = 'pending-questions-container grid-' + layout;
        
        // Remove all active classes
        document.querySelectorAll('.pending-layout-option').forEach(btn => {
          btn.classList.remove('active');
        });
        
        // Add active to current layout
        const activeBtn = document.querySelector(`.pending-layout-option[data-layout="${layout}"]`);
        if (activeBtn) {
          activeBtn.classList.add('active');
        }
        
        // Show all cards
        const questionCards = pendingContainer.querySelectorAll('.pending-question-card');
        questionCards.forEach((card) => {
          card.style.display = 'block';
        });
      }
      
      // Initialize with saved layout
      applyPendingLayout(savedPendingLayout);
      
      // Handle click events
      document.querySelectorAll('.pending-layout-option').forEach(button => {
        button.addEventListener('click', function() {
          const layout = this.dataset.layout;
          console.log('Pending layout button clicked:', layout);
          applyPendingLayout(layout);
          localStorage.setItem('pendingLayout', layout);
        });
      });
    });
    
    // Real-time Filter and Search Functionality for QNA Tab
    document.addEventListener('DOMContentLoaded', function() {
      const sourceFilter = document.getElementById('sourceFilter');
      const searchInput = document.getElementById('searchInput');
      const clearSearchBtn = document.getElementById('clearSearchBtn');
      const filterStatus = document.getElementById('filterStatus');
      const filterStatusText = document.getElementById('filterStatusText');
      const qnaContainer = document.getElementById('qnaContainer');
      const qnaPagination = document.getElementById('qnaPagination');
      const qnaPageInfo = document.getElementById('qnaPageInfo');
      const loadingIndicator = document.getElementById('searchLoadingIndicator');
      
      if (!sourceFilter || !searchInput || !qnaContainer) return;
      
      let currentPage = parseInt('<%= page %>') || 1;
      let currentPageSize = parseInt('<%= pageSize %>') || 6;
      let isSearchActive = false; // Track if real-time filter is active
      
      // Source badge config
      const sourceBadgeConfig = {
        'admin': { icon: '👤', text: 'Admin tạo', color: 'purple' },
        'ai_generated': { icon: '🤖', text: 'AI tạo mới', color: 'primary' },
        'ai_improved': { icon: '💡', text: 'AI cải thiện', color: 'info' },
        'import': { icon: '📊', text: 'Import Excel', color: 'warning' },
        'database': { icon: '💾', text: 'Database cũ', color: 'secondary' }
      };
      
      // Escape HTML to prevent XSS
      function escapeHtmlSafe(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
      }
      
      // Highlight search term in text
      function highlightText(text, searchTerm) {
        if (!searchTerm) return escapeHtmlSafe(text);
        const escaped = escapeHtmlSafe(text);
        const escapedTerm = searchTerm.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        const regex = new RegExp('(' + escapedTerm + ')', 'gi');
        return escaped.replace(regex, '<mark class="bg-warning text-dark px-1 rounded">$1</mark>');
      }
      
      // Render a single question card
      function renderQuestionCard(q, index, page, pageSize, searchTerm) {
        const source = q.source || 'database';
        const badge = sourceBadgeConfig[source] || sourceBadgeConfig['database'];
        const cardNum = index + 1 + (page - 1) * pageSize;
        const questionHtml = highlightText(q.question, searchTerm);
        
        let answersHtml = '';
        if (q.answers && q.answers.length > 0) {
          q.answers.forEach((answer, aIdx) => {
            const answerHtml = highlightText(answer, searchTerm);
            answersHtml += `
              <div class="p-3 bg-light rounded border mb-2">
                <div class="d-flex justify-content-between align-items-start">
                  <div class="flex-grow-1">
                    <small class="text-muted">Trả lời ${aIdx + 1}:</small>
                    <div class="mt-1">${answerHtml}</div>
                  </div>
                </div>
              </div>`;
          });
        } else {
          answersHtml = `
            <div class="p-3 bg-warning bg-opacity-10 rounded border text-warning">
              <i class="fa fa-exclamation-triangle me-2"></i> Chưa có câu trả lời
            </div>`;
        }
        
        // Build edit mode answers
        let editAnswersHtml = '';
        if (q.answers && q.answers.length > 0) {
          q.answers.forEach((answer, aIdx) => {
            editAnswersHtml += `
              <div class="answer-item mb-3">
                <div class="d-flex align-items-start">
                  <div class="flex-grow-1">
                    <label class="form-label small text-muted">Trả lời ${aIdx + 1}:</label>
                    <textarea name="answers[]" class="form-control auto-expand" rows="3" style="resize:vertical; min-height:70px;">${escapeHtmlSafe(answer)}</textarea>
                  </div>
                  <button type="button" class="btn btn-outline-danger btn-sm ms-2 remove-answer" title="Xóa câu trả lời">
                    <i class="fa fa-times"></i>
                  </button>
                </div>
              </div>`;
          });
        } else {
          editAnswersHtml = `
            <div class="answer-item mb-3">
              <div class="d-flex align-items-start">
                <div class="flex-grow-1">
                  <label class="form-label small text-muted">Trả lời 1:</label>
                  <textarea name="answers[]" class="form-control auto-expand" rows="3" style="resize:vertical; min-height:70px;" placeholder="Nhập câu trả lời..."></textarea>
                </div>
                <button type="button" class="btn btn-outline-danger btn-sm ms-2 remove-answer" title="Xóa câu trả lời">
                  <i class="fa fa-times"></i>
                </button>
              </div>
            </div>`;
        }

        return `
          <div class="qna-question-card" data-question-id="${q._id}" data-index="${index}" style="animation: fadeInUp 0.3s ease ${index * 0.05}s both;">
            <div class="card">
              <div class="card-header d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-2">
                  <h6 class="mb-0">
                    <i class="fa fa-question-circle me-2"></i> Câu hỏi #${cardNum}
                  </h6>
                  <span class="badge bg-${badge.color} px-2 py-1" title="Nguồn: ${badge.text}">
                    ${badge.icon} ${badge.text}
                  </span>
                </div>
                <div class="btn-group btn-group-sm">
                  <button type="button" class="btn btn-outline-primary" onclick="toggleEditMode('${q._id}')">
                    <i class="fa fa-edit"></i> Chỉnh sửa
                  </button>
                  <form action="/admin/delete/${q._id}?page=${page}&tab=qna" method="POST" class="d-inline">
                    <button class="btn btn-outline-danger" type="submit" onclick="return confirm('Bạn chắc chắn muốn xóa câu hỏi này?')">
                      <i class="fa fa-trash"></i> Xóa
                    </button>
                  </form>
                </div>
              </div>
              <div class="card-body">
                <div id="view-mode-${q._id}">
                  <div class="mb-3">
                    <label class="form-label fw-bold small text-success">Câu hỏi:</label>
                    <div class="p-3 bg-light rounded border">
                      <i class="fa fa-question-circle text-success me-2"></i>
                      ${questionHtml}
                    </div>
                  </div>
                  <div class="mb-3">
                    <label class="form-label fw-bold small text-primary">Câu trả lời:</label>
                    ${answersHtml}
                  </div>
                </div>
                <div id="edit-mode-${q._id}" style="display: none;">
                  <form action="/admin/edit/${q._id}?page=${page}&tab=qna" method="POST" class="edit-form">
                    <div class="edit-mode-header mb-3">
                      <h6 class="text-success mb-0"><i class="fa fa-edit me-2"></i>Chỉnh sửa câu hỏi & trả lời</h6>
                    </div>
                    <div class="mb-3">
                      <label class="form-label fw-bold small text-success">Câu hỏi:</label>
                      <input type="text" name="question" class="form-control" value="${escapeHtmlSafe(q.question)}" required>
                    </div>
                    <div class="mb-3">
                      <label class="form-label fw-bold small text-primary">Câu trả lời:</label>
                      <div id="answers-container-${q._id}" class="answers-container">
                        ${editAnswersHtml}
                      </div>
                      <button type="button" class="btn btn-outline-primary btn-sm add-answer-btn" data-id="${q._id}">
                        <i class="fa fa-plus me-1"></i> Thêm câu trả lời
                      </button>
                    </div>
                    <div class="edit-actions d-flex gap-2 justify-content-end">
                      <button type="button" class="btn btn-secondary" onclick="toggleEditMode('${q._id}')">
                        <i class="fa fa-times me-1"></i> Hủy
                      </button>
                      <button type="submit" class="btn btn-success">
                        <i class="fa fa-save me-1"></i> Lưu thay đổi
                      </button>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          </div>`;
      }
      
      // Render pagination
      function renderPagination(page, totalPages) {
        if (totalPages <= 1) {
          qnaPagination.innerHTML = '';
          return;
        }
        let startP = Math.max(1, page - 2);
        let endP = Math.min(totalPages, page + 2);
        let html = '<nav aria-label="Page navigation"><ul class="pagination justify-content-center">';
        html += `<li class="page-item ${page === 1 ? 'disabled' : ''}"><a class="page-link" href="#" data-page="${page - 1}">&laquo;</a></li>`;
        if (startP > 1) {
          html += '<li class="page-item"><a class="page-link" href="#" data-page="1">1</a></li>';
          if (startP > 2) html += '<li class="page-item disabled"><span class="page-link">...</span></li>';
        }
        for (let i = startP; i <= endP; i++) {
          html += `<li class="page-item ${page === i ? 'active' : ''}"><a class="page-link" href="#" data-page="${i}">${i}</a></li>`;
        }
        if (endP < totalPages) {
          if (endP < totalPages - 1) html += '<li class="page-item disabled"><span class="page-link">...</span></li>';
          html += `<li class="page-item"><a class="page-link" href="#" data-page="${totalPages}">${totalPages}</a></li>`;
        }
        html += `<li class="page-item ${page === totalPages ? 'disabled' : ''}"><a class="page-link" href="#" data-page="${page + 1}">&raquo;</a></li>`;
        html += '</ul></nav>';
        qnaPagination.innerHTML = html;
        
        // Bind page click events
        qnaPagination.querySelectorAll('a[data-page]').forEach(link => {
          link.addEventListener('click', function(e) {
            e.preventDefault();
            const p = parseInt(this.dataset.page);
            if (p >= 1 && p <= totalPages) {
              currentPage = p;
              fetchQuestions();
            }
          });
        });
      }
      
      // Update source stats cards
      function updateSourceStats(stats) {
        if (!stats) return;
        const totalAll = (stats.admin || 0) + (stats.ai_generated || 0) + (stats.ai_improved || 0) + (stats.import || 0) + (stats.database || 0);
        const el = (id) => document.getElementById(id);
        if (el('statAdmin')) el('statAdmin').textContent = stats.admin || 0;
        if (el('statAdminPct')) el('statAdminPct').textContent = totalAll > 0 ? ((stats.admin / totalAll) * 100).toFixed(1) + '% của tổng' : '0.0% của tổng';
        if (el('statAI')) el('statAI').textContent = (stats.ai_generated || 0) + (stats.ai_improved || 0);
        if (el('statAIDetail')) el('statAIDetail').textContent = `💡 ${stats.ai_improved || 0} cải thiện | 🤖 ${stats.ai_generated || 0} tạo mới`;
        if (el('statOther')) el('statOther').textContent = (stats.import || 0) + (stats.database || 0);
        if (el('statOtherDetail')) el('statOtherDetail').textContent = `📊 ${stats.import || 0} Excel | 💾 ${stats.database || 0} cũ`;
      }
      
      // Update filter status badge
      function updateFilterStatus() {
        const hasFilter = sourceFilter.value !== 'all' || searchInput.value.trim();
        if (hasFilter) {
          let statusText = '';
          if (sourceFilter.value !== 'all') {
            const selectedOption = sourceFilter.options[sourceFilter.selectedIndex].text;
            statusText = `Nguồn: ${selectedOption}`;
          }
          if (searchInput.value.trim()) {
            if (statusText) statusText += ' | ';
            statusText += `Tìm: "${searchInput.value.trim()}"`;
          }
          filterStatusText.textContent = statusText;
          filterStatus.style.display = 'block';
        } else {
          filterStatus.style.display = 'none';
        }
      }
      
      // Fetch questions from API (real-time)
      let fetchController = null;
      async function fetchQuestions() {
        // Abort previous request if still running
        if (fetchController) fetchController.abort();
        fetchController = new AbortController();
        
        const source = sourceFilter.value;
        const search = searchInput.value.trim();
        isSearchActive = (source !== 'all' || search.length > 0);
        
        // Show loading
        if (loadingIndicator) loadingIndicator.style.display = 'inline-block';
        qnaContainer.style.opacity = '0.5';
        qnaContainer.style.transition = 'opacity 0.2s';
        
        updateFilterStatus();
        
        try {
          const params = new URLSearchParams({
            source: source,
            search: search,
            page: currentPage,
            limit: currentPageSize
          });
          
          const res = await fetch(`/api/questions/search?${params}`, {
            signal: fetchController.signal
          });
          const data = await res.json();
          
          if (!data.success) {
            console.error('Search API error:', data.error);
            return;
          }
          
          // Update page info
          if (qnaPageInfo) {
            qnaPageInfo.innerHTML = `Trang ${data.page}/${data.totalPages || 1} - Tổng <strong>${data.total}</strong> câu hỏi` +
              (isSearchActive ? ' <span class="badge bg-info ms-2">🔍 Đang lọc</span>' : '');
          }
          
          // Render question cards
          if (data.questions.length === 0) {
            qnaContainer.innerHTML = `
              <div class="text-center py-5 w-100">
                <i class="fa fa-search fa-3x text-muted mb-3"></i>
                <h5 class="text-muted">Không tìm thấy câu hỏi</h5>
                <p class="text-muted">Thử thay đổi bộ lọc hoặc từ khóa tìm kiếm</p>
              </div>`;
          } else {
            let html = '';
            data.questions.forEach((q, idx) => {
              html += renderQuestionCard(q, idx, data.page, currentPageSize, search);
            });
            qnaContainer.innerHTML = html;
            
            // Rebind add-answer buttons for dynamically rendered cards
            qnaContainer.querySelectorAll('.add-answer-btn').forEach(btn => {
              btn.addEventListener('click', function() {
                const id = this.dataset.id;
                const container = document.getElementById('answers-container-' + id);
                if (!container) return;
                const count = container.querySelectorAll('.answer-item').length + 1;
                const newAnswer = document.createElement('div');
                newAnswer.className = 'answer-item mb-3';
                newAnswer.innerHTML = `
                  <div class="d-flex align-items-start">
                    <div class="flex-grow-1">
                      <label class="form-label small text-muted">Trả lời ${count}:</label>
                      <textarea name="answers[]" class="form-control auto-expand" rows="3" style="resize:vertical; min-height:70px;" placeholder="Nhập câu trả lời..."></textarea>
                    </div>
                    <button type="button" class="btn btn-outline-danger btn-sm ms-2 remove-answer" title="Xóa câu trả lời">
                      <i class="fa fa-times"></i>
                    </button>
                  </div>`;
                container.appendChild(newAnswer);
                newAnswer.querySelector('.remove-answer').addEventListener('click', function() {
                  newAnswer.remove();
                });
              });
            });
            
            // Rebind remove-answer buttons
            qnaContainer.querySelectorAll('.remove-answer').forEach(btn => {
              btn.addEventListener('click', function() {
                const item = this.closest('.answer-item');
                if (item) item.remove();
              });
            });
          }
          
          // Render pagination
          renderPagination(data.page, data.totalPages);
          
          // Update source stats
          updateSourceStats(data.sourceStats);
          
        } catch (e) {
          if (e.name === 'AbortError') return; // Ignore aborted requests
          console.error('Fetch error:', e);
        } finally {
          if (loadingIndicator) loadingIndicator.style.display = 'none';
          qnaContainer.style.opacity = '1';
        }
      }
      
      // Debounce helper
      let searchTimeout;
      function debounceSearch(callback, delay) {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(callback, delay);
      }
      
      // Handle source filter change - instant
      sourceFilter.addEventListener('change', function() {
        currentPage = 1;
        fetchQuestions();
      });
      
      // Handle search input with debounce
      searchInput.addEventListener('input', function() {
        debounceSearch(() => {
          currentPage = 1;
          fetchQuestions();
        }, 400);
      });
      
      // Handle clear search button
      clearSearchBtn.addEventListener('click', function() {
        searchInput.value = '';
        currentPage = 1;
        fetchQuestions();
      });
      
      // Handle Enter key
      searchInput.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
          e.preventDefault();
          clearTimeout(searchTimeout);
          currentPage = 1;
          fetchQuestions();
        }
      });
    });
    
    // Toast Notification System
    const toastContainer = document.createElement('div');
    toastContainer.className = 'toast-container';
    document.body.appendChild(toastContainer);
    
    function showToast(message, type = 'success', duration = 5000) {
      const toast = document.createElement('div');
      toast.className = `custom-toast toast-${type}`;
      toast.innerHTML = `
        <div class="toast-header">
          <i class="fa ${type === 'success' ? 'fa-check-circle text-success' : type === 'info' ? 'fa-info-circle text-info' : type === 'warning' ? 'fa-exclamation-triangle text-warning' : 'fa-times-circle text-danger'} me-2"></i>
          <strong class="me-auto">${type === 'success' ? 'Thành công' : type === 'info' ? 'Thông báo' : type === 'warning' ? 'Cảnh báo' : 'Lỗi'}</strong>
          <small class="text-muted">vừa xong</small>
          <button type="button" class="btn-close" onclick="this.parentElement.parentElement.remove()"></button>
        </div>
        <div class="toast-body">${message}</div>
      `;
      
      toastContainer.appendChild(toast);
      
      setTimeout(() => {
        toast.style.animation = 'slideOutRight 0.3s ease';
        setTimeout(() => toast.remove(), 300);
      }, duration);
    }
    
    // Auto-refresh badges every 30 seconds
    let lastTotalQuestions = <%= totalQuestions %>;
    let lastTotalPending = <%= totalPending %>;
    let lastNewToday = <%= newQuestionsToday %>;
    
    async function refreshBadges() {
      try {
        const response = await fetch('/api/admin/stats');
        const data = await response.json();
        
        if (data.success) {
          // Update QNA badge
          const qnaBadge = document.querySelector('#qna-tab .badge.bg-success');
          if (qnaBadge) {
            qnaBadge.textContent = `${data.totalQuestions}`;
          }
          
          // Update Pending badge
          const pendingBadge = document.querySelector('#pending-tab .badge.bg-danger');
          if (pendingBadge) {
            pendingBadge.textContent = `${data.totalPending}`;
            if (data.totalPending > lastTotalPending) {
              showToast(`Có ${data.totalPending - lastTotalPending} câu hỏi mới cần trả lời!`, 'warning');
              if (!pendingBadge.classList.contains('pulse-badge')) {
                pendingBadge.classList.add('pulse-badge');
              }
            }
          }
          
          // Update New Today badge
          if (data.newQuestionsToday > lastNewToday) {
            showToast(`AI đã thêm ${data.newQuestionsToday - lastNewToday} câu hỏi mới vào database!`, 'info');
            
            // Add or update badge
            let newBadge = document.querySelector('#qna-tab .badge.bg-info');
            if (data.newQuestionsToday > 0) {
              if (!newBadge) {
                newBadge = document.createElement('span');
                newBadge.className = 'badge bg-info ms-1 pulse-badge';
                newBadge.title = 'Mới hôm nay';
                qnaBadge.parentElement.insertBefore(newBadge, qnaBadge.nextSibling);
              }
              newBadge.textContent = `+${data.newQuestionsToday}`;
            }
          }
          
          lastTotalQuestions = data.totalQuestions;
          lastTotalPending = data.totalPending;
          lastNewToday = data.newQuestionsToday;
        }
      } catch (error) {
        console.error('Error refreshing badges:', error);
      }
    }
    
    // Refresh badges every 30 seconds
    setInterval(refreshBadges, 30000);
    
    // Show welcome toast on page load
    <% if (newQuestionsToday > 0) { %>
    setTimeout(() => {
      showToast('Có <%= newQuestionsToday %> câu hỏi mới được thêm hôm nay bởi AI!', 'info', 8000);
    }, 1000);
    <% } %>
    
    <% if (totalPending > 0) { %>
    setTimeout(() => {
      showToast('Có <%= totalPending %> câu hỏi đang chờ trả lời!', 'warning', 8000);
    }, 2000);
    <% } %>
  </script>
</body>
</html>