          <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
              <li class="page-item <%= pagePending === 1 ? 'disabled' : '' %>">
                <a class="page-link" href="/admin?tab=pending&pagePending=<%= pagePending - 1 %>" tabindex="-1">&laquo;</a>
              </li>
              <% 
                let startPagePending = Math.max(1, pagePending - 2);
                let endPagePending = Math.min(totalPagesPending, pagePending + 2);
                
                if (startPagePending > 1) { %>
                  <li class="page-item"><a class="page-link" href="/admin?tab=pending&pagePending=1">1</a></li>
                  <% if (startPagePending > 2) { %>
                    <li class="page-item disabled"><span class="page-link">...</span></li>
                  <% } %>
                <% }
                
                for (let i = startPagePending; i <= endPagePending; i++) { %>
                  <li class="page-item <%= pagePending === i ? 'active' : '' %>"><a class="page-link" href="/admin?tab=pending&pagePending=<%= i %>"><%= i %></a></li>
                <% }
                
                if (endPagePending < totalPagesPending) { %>
                  <% if (endPagePending < totalPagesPending - 1) { %>
                    <li class="page-item disabled"><span class="page-link">...</span></li>
                  <% } %>
                  <li class="page-item"><a class="page-link" href="/admin?tab=pending&pagePending=<%= totalPagesPending %>"><%= totalPagesPending %></a></li>
                <% } %>
              <li class="page-item <%= pagePending === totalPagesPending ? 'disabled' : '' %>">
                <a class="page-link" href="/admin?tab=pending&pagePending=<%= pagePending + 1 %>">&raquo;</a>
              </li>
            </ul>
          </nav>
          <% } %>
        </div>
        <% } %>
      </div>
      
