    function toggleAI() {
      const aiToggle = document.getElementById('aiToggleSwitch');
      const aiToggleText = document.getElementById('aiToggleText');
      if (!aiToggle || !aiToggleText) return;
      
      const isEnabled = aiToggle.checked;
      
      fetch('/api/settings/ai-enabled', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ value: isEnabled })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          aiToggleText.textContent = isEnabled ? 'Đang bật' : 'Đang tắt';
          const message = isEnabled ? 'AI đã được bật!' : 'AI đã được tắt!';
          alert(message);
          
          // Update header status display
          updateAIStatusDisplay(isEnabled);
        } else {
          // Revert toggle if save failed
          aiToggle.checked = !isEnabled;
          aiToggleText.textContent = !isEnabled ? 'Đang bật' : 'Đang tắt';
          alert('Lỗi khi thay đổi trạng thái AI: ' + data.message);
        }
      })
      .catch(error => {
        // Revert toggle if request failed
        aiToggle.checked = !isEnabled;
