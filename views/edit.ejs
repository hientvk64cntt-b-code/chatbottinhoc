<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Sửa câu hỏi</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body>
  <div class="container mt-4">
    <h2>Sửa câu hỏi</h2>
    <form id="editForm" action="/admin/edit/<%= q._id %>" method="POST">
      <div class="mb-3">
        <label for="question" class="form-label">Câu hỏi</label>
        <input type="text" class="form-control" id="question" name="question" value="<%= q.question %>" required>
      </div>
      <div class="mb-3">
        <label for="answers" class="form-label">Trả lời</label>
        <div id="answers-container">
          <% q.answers.forEach(answer => { %>
            <textarea class="form-control mb-2" name="answers[]" required><%= answer %></textarea>
          <% }) %>
        </div>
        <button type="button" class="btn btn-sm btn-outline-primary" id="add-answer">Thêm câu trả lời</button>
      </div>
      <button type="submit" class="btn btn-primary">Lưu</button>
      <a href="/admin" class="btn btn-secondary">Quay lại</a>
    </form>
  </div>
  <script>
    // Cảnh báo khi click ra ngoài form nếu có thay đổi chưa lưu
    let isDirty = false;
    const form = document.getElementById('editForm');
    const inputs = form.querySelectorAll('input, textarea');
    inputs.forEach(function(input) {
      input.addEventListener('input', function() {
        isDirty = true;
      });
    });
    // Cảnh báo khi reload/tab close
    window.addEventListener('beforeunload', function (e) {
      if (isDirty) {
        e.preventDefault();
        e.returnValue = '';
        return '';
      }
    });
    // Reset isDirty khi submit
    form.addEventListener('submit', function() {
      isDirty = false;
    });
    // Cảnh báo khi click ra ngoài form
    document.addEventListener('mousedown', function(e) {
      if (isDirty && !form.contains(e.target)) {
        let confirmLeave = confirm('Bạn có muốn lưu thay đổi trước khi rời khỏi vùng chỉnh sửa không?');
        if (!confirmLeave) {
          isDirty = false;
        } else {
          form.submit();
          isDirty = false;
        }
      }
    });
    document.getElementById('add-answer').addEventListener('click', function() {
      const container = document.getElementById('answers-container');
      const textarea = document.createElement('textarea');
      textarea.className = 'form-control mb-2';
      textarea.name = 'answers[]';
      container.appendChild(textarea);
    });
  </script>
</body>
</html>